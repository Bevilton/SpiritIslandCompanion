@* Sidebar + content area chrome. Used by MainLayout and ReferenceLayout (authenticated branch).
   Outer container is locked to h-screen (not min-h-screen) so <main> below becomes the actual
   scroll container — that's what makes sticky elements inside the page (right summary panel,
   bottom action bar) work as expected. *@

<div class="h-screen flex bg-ink-50">
    <aside class="hidden md:flex w-60 shrink-0 flex-col bg-white border-r border-ink-200">
        <div class="px-5 h-16 flex items-center border-b border-ink-200">
            <AuthorizeView>
                <Authorized><Logo Href="/app/dashboard"/></Authorized>
                <NotAuthorized><Logo Href="/"/></NotAuthorized>
            </AuthorizeView>
        </div>

        <div class="flex-1 overflow-y-auto p-3">
            <NavMenu/>
        </div>

        <div class="p-3 border-t border-ink-200">
            <AuthorizeView>
                <Authorized>
                    <div class="flex items-center gap-3 px-2 py-1.5">
                        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent-100 text-accent-800 text-sm font-medium">
                            @GetInitial(context.User.FindFirst("nickname")?.Value ?? context.User.Identity?.Name)
                        </span>
                        <div class="flex-1 min-w-0">
                            <div class="text-sm font-medium text-ink-900 truncate">
                                @(context.User.FindFirst("nickname")?.Value ?? context.User.Identity?.Name)
                            </div>
                            <a href="/logout" class="text-xs text-ink-500 hover:text-ink-700 inline-flex items-center gap-1">
                                <Icon Name="logout" Class="w-3.5 h-3.5"/> Sign out
                            </a>
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-secondary w-full">
                        <Icon Name="login" Class="w-4 h-4"/> Sign in
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </aside>

    <div class="flex-1 flex flex-col min-w-0">
        <header class="md:hidden h-14 px-4 flex items-center justify-between bg-white border-b border-ink-200">
            <AuthorizeView>
                <Authorized><Logo Href="/app/dashboard"/></Authorized>
                <NotAuthorized><Logo Href="/"/></NotAuthorized>
            </AuthorizeView>
            <a href="/" class="text-sm text-ink-600">Home</a>
        </header>
        <main class="flex-1 overflow-y-auto">
            <div class="mx-auto max-w-6xl px-4 md:px-8 py-6 md:py-10">
                @ChildContent
            </div>
        </main>
    </div>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private static string GetInitial(string? name)
        => string.IsNullOrWhiteSpace(name) ? "?" : char.ToUpperInvariant(name.Trim()[0]).ToString();
}
