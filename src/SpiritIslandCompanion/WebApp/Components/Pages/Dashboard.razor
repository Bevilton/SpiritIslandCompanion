@page "/app/dashboard"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>Dashboard</PageTitle>

<div class="page-head">
    <div>
        <span class="eyebrow">Welcome back</span>
        <h1 class="page-title mt-2">Dashboard</h1>
    </div>
    <a href="/app/games/new" class="btn btn-primary">
        <Icon Name="plus" Class="w-4 h-4"/> New game
    </a>
</div>

@if (_loading)
{
    <LoadingSpinner/>
}
else
{
    @if (_pendingCount > 0)
    {
        <div class="alert alert-info mb-6">
            <Icon Name="users" Class="w-5 h-5 shrink-0"/>
            <div class="flex-1">
                You have <strong>@_pendingCount</strong> pending friend request@(_pendingCount == 1 ? "" : "s").
                <a href="/app/friends" class="font-medium underline">View</a>
            </div>
        </div>
    }

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <StatCard Value="@(_stats?.TotalGames.ToString() ?? "0")" Label="Total games" Icon="controller"/>
        <StatCard Value="@($"{_stats?.WinRate ?? 0:F0}%")" Label="Win rate" Icon="trophy"/>
        <StatCard Value="@($"{_stats?.AverageScore ?? 0:F0}")" Label="Avg score" Icon="chart"/>
        <StatCard Value="@(_stats?.InProgress.ToString() ?? "0")" Label="In progress" Icon="hourglass"/>
    </div>

    <div class="surface">
        <div class="surface-head">
            <h2 class="text-base font-semibold">Recent games</h2>
            <a href="/app/games" class="text-sm text-accent-700 hover:text-accent-800 inline-flex items-center gap-1">
                View all <Icon Name="arrow-right" Class="w-3.5 h-3.5"/>
            </a>
        </div>

        @if (_games is null || _games.Count == 0)
        {
            <div class="px-6 py-12 text-center">
                <p class="text-ink-600">No games recorded yet.</p>
                <a href="/app/games/new" class="btn btn-primary mt-4">Record your first game</a>
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="table table-hover">
                    <thead>
                    <tr>
                        <th>Date</th>
                        <th>Adversary</th>
                        <th>Players</th>
                        <th>Difficulty</th>
                        <th>Result</th>
                        <th class="text-right">Score</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var g in _games.Take(5))
                    {
                        <tr @onclick='() => Nav.NavigateTo($"/app/games/{g.Id}")'>
                            <td class="text-ink-600">@g.StartedAt.LocalDateTime.ToString("MMM dd, yyyy")</td>
                            <td class="font-medium text-ink-900">@(g.AdversaryNames.Count > 0 ? string.Join(" + ", g.AdversaryNames) : "—")</td>
                            <td>@g.PlayerCount</td>
                            <td>@g.Difficulty</td>
                            <td><GameStatusBadge IsCompleted="g.IsCompleted" Win="g.Win"/></td>
                            <td class="text-right font-medium">@(g.Score?.ToString() ?? "—")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private Application.Features.Statistics.StatisticsResponse? _stats;
    private List<Application.Features.Games.ListGamesResponse>? _games;
    private int _pendingCount;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser.UserId is not { } userId) return;

        var statsResult = await Mediator.Send(new Application.Features.Statistics.GetStatisticsQuery(userId));
        var gamesResult = await Mediator.Send(new Application.Features.Games.ListGamesQuery(userId));
        var pendingResult = await Mediator.Send(new Application.Features.Friendships.ListPendingRequestsQuery(userId));

        if (statsResult.IsSuccess) _stats = statsResult.Value;
        if (gamesResult.IsSuccess) _games = gamesResult.Value;
        if (pendingResult.IsSuccess) _pendingCount = pendingResult.Value.Incoming.Count;

        _loading = false;
    }
}
