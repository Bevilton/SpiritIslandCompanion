@page "/app/players"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser

<PageTitle>Players</PageTitle>

<div class="page-head">
    <div>
        <h1 class="page-title">Local players</h1>
        <p class="page-sub">Guest players who don't have an account.</p>
    </div>
</div>

<Alert Message="@_message" Type="@_alertType"/>
<FormErrorSummary Errors="@_errors"/>

@if (_loading)
{
    <LoadingSpinner/>
}
else
{
    <section class="surface mb-5">
        <div class="surface-body">
            <div class="flex flex-col sm:flex-row gap-2 max-w-md">
                <div class="flex-1">
                    <input type="text" class="input w-full" placeholder="Player name…"
                           @bind="_newPlayerName" @bind:event="oninput"
                           @onkeydown="HandleKeyDown"/>
                    <FieldError For="Name" Errors="@_errors"/>
                </div>
                <button class="btn btn-primary self-start" @onclick="AddPlayer" disabled="@string.IsNullOrWhiteSpace(_newPlayerName)">
                    <Icon Name="plus" Class="w-4 h-4"/> Add
                </button>
            </div>
        </div>
    </section>

    <section class="surface">
        @if (_players.Count == 0)
        {
            <div class="px-6 py-12 text-center text-ink-500">No local players yet.</div>
        }
        else
        {
            <ul class="divide-y divide-ink-100">
                @foreach (var p in _players)
                {
                    <li class="px-5 md:px-6 py-3 flex items-center justify-between gap-4">
                        @if (_editingId == p.Id)
                        {
                            <div class="flex flex-1 gap-2 max-w-md">
                                <div class="flex-1">
                                    <input type="text" class="input w-full" @bind="_editName"/>
                                    <FieldError For="Name" Errors="@_errors"/>
                                </div>
                                <button class="btn btn-sm btn-primary self-start" @onclick="SaveEdit"><Icon Name="check" Class="w-3.5 h-3.5"/></button>
                                <button class="btn btn-sm btn-secondary self-start" @onclick="CancelEdit"><Icon Name="x" Class="w-3.5 h-3.5"/></button>
                            </div>
                        }
                        else
                        {
                            <div class="flex items-center gap-3 min-w-0">
                                <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-ink-100 text-ink-700 text-sm font-medium shrink-0">
                                    @(string.IsNullOrEmpty(p.Name) ? "?" : char.ToUpperInvariant(p.Name[0]).ToString())
                                </span>
                                <span class="font-medium text-ink-900 truncate">@p.Name</span>
                            </div>
                            <div class="flex gap-2 shrink-0">
                                <button class="btn btn-sm btn-secondary" @onclick="() => StartEdit(p)">
                                    <Icon Name="edit" Class="w-3.5 h-3.5"/>
                                </button>
                                <button class="btn btn-sm btn-danger-outline" @onclick="() => DeletePlayer(p.Id)">
                                    <Icon Name="trash" Class="w-3.5 h-3.5"/>
                                </button>
                            </div>
                        }
                    </li>
                }
            </ul>
        }
    </section>

    <ConfirmDialog @ref="_confirmDialog" Title="Delete player" Message="Are you sure you want to delete this player?"/>
}

@code {
    private List<Application.Features.Players.ListPlayersResponse> _players = [];
    private bool _loading = true;
    private string _newPlayerName = "";
    private string? _message;
    private string _alertType = "success";
    private FormErrors _errors = FormErrors.Empty;

    private Guid? _editingId;
    private string _editName = "";

    private ConfirmDialog _confirmDialog = default!;

    private void HandleResult(Domain.Results.Result result, string successMessage, string successAlertType = "success")
    {
        _errors = FormErrors.FromResult(result);
        if (result.IsSuccess)
        {
            _message = successMessage;
            _alertType = successAlertType;
        }
        else if (_errors.Any)
        {
            _message = null;
        }
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        if (CurrentUser.UserId is not { } userId) return;
        var result = await Mediator.Send(new Application.Features.Players.ListPlayersQuery(userId));
        if (result.IsSuccess) _players = result.Value;
        _loading = false;
    }

    private async Task AddPlayer()
    {
        var result = await Mediator.Send(new Application.Features.Players.CreatePlayerCommand(_newPlayerName, CurrentUser.UserId!.Value));
        HandleResult(result, "Player added.");
        if (result.IsSuccess)
        {
            _newPlayerName = "";
            await LoadData();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newPlayerName))
            await AddPlayer();
    }

    private void StartEdit(Application.Features.Players.ListPlayersResponse player)
    {
        _editingId = player.Id;
        _editName = player.Name;
    }

    private void CancelEdit() => _editingId = null;

    private async Task SaveEdit()
    {
        if (_editingId is null) return;
        var result = await Mediator.Send(new Application.Features.Players.UpdatePlayerCommand(_editingId.Value, _editName));
        HandleResult(result, "Player updated.");
        if (result.IsSuccess)
        {
            _editingId = null;
            await LoadData();
        }
    }

    private async Task DeletePlayer(Guid id)
    {
        if (!await _confirmDialog.ShowAsync()) return;
        var result = await Mediator.Send(new Application.Features.Players.DeletePlayerCommand(id));
        HandleResult(result, "Player deleted.", "info");
        await LoadData();
    }
}
