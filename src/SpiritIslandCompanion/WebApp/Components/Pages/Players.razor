@page "/players"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser

<PageTitle>Players</PageTitle>

<div class="page-header">
    <h1>Local Players</h1>
    <p class="text-muted mb-0">Manage guest players who don't have their own account.</p>
</div>

<Alert Message="@_message" Type="@_alertType"/>

@if (_loading)
{
    <LoadingSpinner/>
}
else
{
    @* Add Player *@
    <div class="card mb-4">
        <div class="card-body">
            <div class="input-group" style="max-width: 400px;">
                <input type="text" class="form-control" placeholder="Player name..."
                       @bind="_newPlayerName" @bind:event="oninput"
                       @onkeydown="HandleKeyDown"/>
                <button class="btn btn-primary" @onclick="AddPlayer" disabled="@string.IsNullOrWhiteSpace(_newPlayerName)">
                    <i class="bi bi-plus-lg me-1"></i> Add
                </button>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            @if (_players.Count == 0)
            {
                <div class="text-muted text-center py-4">No local players yet.</div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var p in _players)
                    {
                        <div class="list-group-item d-flex align-items-center justify-content-between">
                            @if (_editingId == p.Id)
                            {
                                <div class="input-group input-group-sm" style="max-width: 300px;">
                                    <input type="text" class="form-control" @bind="_editName"/>
                                    <button class="btn btn-success" @onclick="SaveEdit"><i class="bi bi-check-lg"></i></button>
                                    <button class="btn btn-outline-secondary" @onclick="CancelEdit"><i class="bi bi-x-lg"></i></button>
                                </div>
                            }
                            else
                            {
                                <span>@p.Name</span>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(p)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePlayer(p.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <ConfirmDialog @ref="_confirmDialog" Title="Delete Player" Message="Are you sure you want to delete this player?"/>
}

@code {
    private List<Application.Features.Players.ListPlayersResponse> _players = [];
    private bool _loading = true;
    private string _newPlayerName = "";
    private string? _message;
    private string _alertType = "success";

    // Edit state
    private Guid? _editingId;
    private string _editName = "";

    private ConfirmDialog _confirmDialog = default!;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        if (CurrentUser.UserId is not { } userId) return;
        var result = await Mediator.Send(new Application.Features.Players.ListPlayersQuery(userId));
        if (result.IsSuccess) _players = result.Value;
        _loading = false;
    }

    private async Task AddPlayer()
    {
        var result = await Mediator.Send(new Application.Features.Players.CreatePlayerCommand(_newPlayerName, CurrentUser.UserId!.Value));
        if (result.IsSuccess)
        {
            _newPlayerName = "";
            _message = "Player added!";
            _alertType = "success";
            await LoadData();
        }
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newPlayerName))
            await AddPlayer();
    }

    private void StartEdit(Application.Features.Players.ListPlayersResponse player)
    {
        _editingId = player.Id;
        _editName = player.Name;
    }

    private void CancelEdit() => _editingId = null;

    private async Task SaveEdit()
    {
        if (_editingId is null) return;
        var result = await Mediator.Send(new Application.Features.Players.UpdatePlayerCommand(_editingId.Value, _editName));
        if (result.IsSuccess)
        {
            _editingId = null;
            _message = "Player updated!";
            _alertType = "success";
            await LoadData();
        }
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    private async Task DeletePlayer(Guid id)
    {
        if (!await _confirmDialog.ShowAsync()) return;
        var result = await Mediator.Send(new Application.Features.Players.DeletePlayerCommand(id));
        _message = result.IsSuccess ? "Player deleted." : result.Error.Message;
        _alertType = result.IsSuccess ? "info" : "danger";
        await LoadData();
    }
}
