@page "/app/games"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>Games</PageTitle>

<div class="page-head">
    <div>
        <h1 class="page-title">Games</h1>
        <p class="page-sub">Every match you've recorded.</p>
    </div>
    <a href="/app/games/new" class="btn btn-primary">
        <Icon Name="plus" Class="w-4 h-4"/> New game
    </a>
</div>

@if (_loading)
{
    <LoadingSpinner/>
}
else
{
    <div class="flex items-center gap-2 mb-4">
        <FilterPill Active="@(_filter == "all")" OnToggle='() => SetFilter("all")'>
            All <span class="ml-1 text-ink-500 tabular-nums">@_games.Count</span>
        </FilterPill>
        <FilterPill Active="@(_filter == "completed")" OnToggle='() => SetFilter("completed")'>
            Completed <span class="ml-1 text-ink-500 tabular-nums">@_games.Count(g => g.IsCompleted)</span>
        </FilterPill>
        <FilterPill Active="@(_filter == "draft")" OnToggle='() => SetFilter("draft")'>
            Drafts <span class="ml-1 text-ink-500 tabular-nums">@_games.Count(g => !g.IsCompleted)</span>
        </FilterPill>
    </div>

    <div class="surface">
        @if (FilteredGames.Count == 0)
        {
            <div class="px-6 py-16 text-center text-ink-500">
                <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-ink-100 text-ink-500 mb-3">
                    <Icon Name="trophy" Class="w-5 h-5"/>
                </div>
                <p class="text-sm">No games match this filter.</p>
                @if (_filter == "all")
                {
                    <a href="/app/games/new" class="btn btn-primary mt-4">Record your first game</a>
                }
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="table table-hover">
                    <thead>
                    <tr>
                        <th class="whitespace-nowrap">Date</th>
                        <th>Adversary</th>
                        <th>Scenario</th>
                        <th>Players</th>
                        <th class="text-center">Difficulty</th>
                        <th>Result</th>
                        <th class="text-right">Score</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var g in FilteredGames)
                    {
                        var adversaries = g.AdversaryIds
                            .Select(id => GameLookups.AdversaryFor(id))
                            .Where(a => a is not null)
                            .ToList();
                        var scenario = GameLookups.ScenarioFor(g.ScenarioId);

                        <tr @onclick='() => Nav.NavigateTo($"/app/games/{g.Id}")' class="cursor-pointer">
                            <td class="whitespace-nowrap">
                                <div class="text-sm text-ink-900 font-medium">@g.StartedAt.LocalDateTime.ToString("MMM dd")</div>
                                <div class="text-[11px] text-ink-500">@g.StartedAt.LocalDateTime.ToString("yyyy")</div>
                            </td>
                            <td>
                                @if (adversaries.Count == 0)
                                {
                                    <span class="text-ink-400 text-sm">—</span>
                                }
                                else
                                {
                                    <div class="flex items-center gap-2 min-w-0">
                                        <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-accent-50 text-accent-700 shrink-0">
                                            <Icon Name="shield" Class="w-3.5 h-3.5"/>
                                        </span>
                                        <span class="text-sm text-ink-900 font-medium truncate">
                                            @string.Join(" + ", adversaries.Select(a => a!.Name))
                                        </span>
                                    </div>
                                }
                            </td>
                            <td>
                                @if (scenario is null)
                                {
                                    <span class="text-ink-400 text-sm">—</span>
                                }
                                else
                                {
                                    <div class="flex items-center gap-2 min-w-0">
                                        <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-accent-100 text-accent-700 shrink-0">
                                            <Icon Name="book" Class="w-3.5 h-3.5"/>
                                        </span>
                                        <span class="text-sm text-ink-700 truncate">@scenario.Name</span>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="flex flex-wrap items-center gap-x-2 gap-y-1 min-w-0">
                                    @foreach (var p in g.Players.Take(3))
                                    {
                                        <span class="inline-flex items-center gap-1 min-w-0" title="@p.Name">
                                            <span class="@PlayerAvatarClass(p.Kind)">@PlayerInitial(p.Name)</span>
                                            <span class="text-sm @(p.Kind == Application.Features.Games.GamePlayerKind.Me ? "text-accent-800 font-medium" : "text-ink-700") truncate max-w-[8rem]">@p.Name</span>
                                        </span>
                                    }
                                    @if (g.Players.Count > 3)
                                    {
                                        <span class="text-xs text-ink-500 font-medium">+@(g.Players.Count - 3)</span>
                                    }
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="inline-flex min-w-7 h-7 items-center justify-center px-2 rounded-lg bg-accent-50 text-accent-800 text-sm font-semibold tabular-nums" style="font-family: var(--font-serif);">
                                    @g.Difficulty
                                </span>
                            </td>
                            <td><GameStatusBadge IsCompleted="g.IsCompleted" Win="g.Win"/></td>
                            <td class="text-right">
                                @if (g.Score is { } score)
                                {
                                    <span class="text-base font-semibold tabular-nums @(g.Win == true ? "text-accent-800" : "text-red-700")" style="font-family: var(--font-serif);">@score</span>
                                }
                                else
                                {
                                    <span class="text-ink-400 text-sm">—</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private List<Application.Features.Games.ListGamesResponse> _games = [];
    private string _filter = "all";
    private bool _loading = true;

    private List<Application.Features.Games.ListGamesResponse> FilteredGames => _filter switch
    {
        "completed" => _games.Where(g => g.IsCompleted).ToList(),
        "draft" => _games.Where(g => !g.IsCompleted).ToList(),
        _ => _games
    };

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser.UserId is not { } userId) return;
        var result = await Mediator.Send(new Application.Features.Games.ListGamesQuery(userId));
        if (result.IsSuccess) _games = result.Value;
        _loading = false;
    }

    private void SetFilter(string filter) => _filter = filter;

    private static string PlayerAvatarClass(Application.Features.Games.GamePlayerKind kind) => kind switch
    {
        Application.Features.Games.GamePlayerKind.Me     => "inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent-600 text-white text-[10px] font-semibold shrink-0",
        Application.Features.Games.GamePlayerKind.Friend => "inline-flex h-5 w-5 items-center justify-center rounded-full bg-sky-100 text-sky-700 text-[10px] font-semibold ring-1 ring-sky-200 shrink-0",
        Application.Features.Games.GamePlayerKind.Local  => "inline-flex h-5 w-5 items-center justify-center rounded-full bg-ink-100 text-ink-600 text-[10px] font-semibold ring-1 ring-ink-200 shrink-0",
        _                                                => "inline-flex h-5 w-5 items-center justify-center rounded-full bg-ink-100 text-ink-400 text-[10px] font-semibold shrink-0",
    };

    private static string PlayerInitial(string name) =>
        string.IsNullOrWhiteSpace(name)
            ? "?"
            : char.ToUpperInvariant(name.TrimStart()[0]).ToString();
}
