@code {
    private RenderFragment BoardsTab() =>
        @<div class="space-y-6">
            @{
                var topBoard = _stats!.BoardStatistics.OrderByDescending(b => b.GamesPlayed).FirstOrDefault();
                var bestBoard = _stats.BoardStatistics.Where(b => b.GamesPlayed >= 3).OrderByDescending(b => b.WinRate).FirstOrDefault();
                var playedIds = _stats.BoardStatistics.Select(b => b.BoardId).ToHashSet();
                var ownedBoards = OwnedBoardsList();
                var missing = ownedBoards.Where(b => !playedIds.Contains(b.Id.Value)).Cast<object>().ToList();
            }

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                @if (topBoard is not null) { @BoardInsight("Most played board", topBoard, $"{topBoard.GamesPlayed} games", null) }
                @if (bestBoard is not null && bestBoard.BoardId != topBoard?.BoardId) { @BoardInsight("Highest win rate", bestBoard, $"{bestBoard.WinRate:F0}%", "text-accent-700") }
            </div>

            @if (_stats.BoardStatistics.Count > 0)
            {
                <div class="surface">
                    <div class="surface-head"><h2 class="text-base font-semibold">All boards played</h2></div>
                    <div class="table-wrap">
                        <table class="table">
                            <thead><tr><th>Board</th><th class="text-right">Games</th><th class="text-right">W</th><th class="text-right">L</th><th>Win rate</th></tr></thead>
                            <tbody>
                            @foreach (var b in _stats.BoardStatistics)
                            {
                                var board = GameLookups.BoardFor(b.BoardId);
                                var detail = board is null ? null : BoardDetails.For(board.Id);
                                var color = detail?.ColorHex ?? "#78716c";
                                var letter = detail?.Letter ?? (board is null ? "?" : board.Name[^1..]);
                                <tr>
                                    <td>
                                        <div class="flex items-center gap-3 min-w-0">
                                            <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-white text-sm font-semibold shrink-0" style="background-color: @color; font-family: var(--font-serif);">@letter</span>
                                            <div class="min-w-0">
                                                <div class="text-sm font-semibold text-ink-900 truncate">@(board?.Name ?? b.BoardId)</div>
                                                @if (detail is not null) { <div class="text-[11px] text-ink-500 truncate">@detail.ThematicName</div> }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-right tabular-nums">@b.GamesPlayed</td>
                                    <td class="text-right text-accent-700 tabular-nums">@b.Wins</td>
                                    <td class="text-right text-red-600 tabular-nums">@b.Losses</td>
                                    <td><WinRateBar Pct="b.WinRate"/></td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <CoveragePanel Title="Boards" Total="ownedBoards.Count" Missing="missing" ItemTemplate="BoardPill"/>
        </div>;

    private RenderFragment<object> BoardPill => o =>
        @<text>
            @{
                var board = (Domain.Models.Static.Board)o;
                var detail = BoardDetails.For(board.Id);
                var color = detail?.ColorHex ?? "#78716c";
                var letter = detail?.Letter ?? board.Name[^1..];
            }
            <span class="inline-flex items-center gap-1.5 rounded-full border border-ink-200 bg-white px-2.5 py-1 text-xs">
                <span class="inline-flex h-5 w-5 items-center justify-center rounded text-white text-[10px] font-semibold" style="background-color: @color; font-family: var(--font-serif);">@letter</span>
                <span class="text-ink-700">@board.Name</span>
            </span>
        </text>;

    private RenderFragment BoardInsight(string title, Application.Features.Statistics.BoardStats b, string metric, string? metricColor) =>
        @<text>
            @{
                var board = GameLookups.BoardFor(b.BoardId);
                var detail = board is null ? null : BoardDetails.For(board.Id);
            }
            <InsightCard Title="@title"
                         Subject="@(board?.Name ?? b.BoardId)"
                         Secondary="@(detail?.ThematicName)"
                         Metric="@metric"
                         MetricColorClass="@(metricColor ?? "text-ink-900")"
                         AccentColor="@(detail?.ColorHex)"/>
        </text>;
}

@code {
    [CascadingParameter(Name = "OwnedExpansions")]
    public IReadOnlyList<ExpansionId>? OwnedExpansions { get; set; }

    private Application.Features.Statistics.StatisticsResponse? _stats;
    private List<Application.Features.Statistics.PlayerStats> _unfilteredPlayers = [];
    private Application.Features.Statistics.PlayerStats? _scoped;
    private bool _loading = true;
    private bool _scopeOpen;
    private string _tab = "overview";

    private record TabDef(string Key, string Label);
    private readonly TabDef[] _tabs =
    [
        new("overview", "Overview"),
        new("spirits", "Spirits"),
        new("adversaries", "Adversaries"),
        new("scenarios", "Scenarios"),
        new("boards", "Boards"),
    ];

    private string TabClass(string key)
        => key == _tab
            ? "px-4 py-2.5 text-sm font-medium text-accent-800 border-b-2 border-accent-600 -mb-px whitespace-nowrap"
            : "px-4 py-2.5 text-sm text-ink-500 hover:text-ink-800 border-b-2 border-transparent -mb-px whitespace-nowrap";

    private void SetTab(string key) => _tab = key;

    public sealed record MissingLevel(string AdversaryId, string AdversaryName, int Level);
    public sealed record MissingAdversaryGroup(string AdversaryId, string AdversaryName, List<int> Levels);

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser.UserId is not { } userId) return;
        await LoadStats(scopeUserId: null, scopePlayerId: null);
        _unfilteredPlayers = _stats?.PlayerStatistics ?? [];
        _loading = false;
    }

    private async Task LoadStats(Guid? scopeUserId, Guid? scopePlayerId)
    {
        if (CurrentUser.UserId is not { } userId) return;
        var query = new Application.Features.Statistics.GetStatisticsQuery(userId, scopeUserId, scopePlayerId);
        var result = await Mediator.Send(query);
        if (result.IsSuccess) _stats = result.Value;
    }

    private void ToggleScopePicker() => _scopeOpen = !_scopeOpen;

    private async Task SetScope(Application.Features.Statistics.PlayerStats? player)
    {
        _scopeOpen = false;
        if (SameScope(player, _scoped)) return;

        _scoped = player;
        _loading = true;
        StateHasChanged();
        await LoadStats(player?.UserId, player?.PlayerId);
        _loading = false;
    }

    private static bool SameScope(
        Application.Features.Statistics.PlayerStats? a,
        Application.Features.Statistics.PlayerStats? b)
    {
        if (a is null && b is null) return true;
        if (a is null || b is null) return false;
        return a.UserId == b.UserId && a.PlayerId == b.PlayerId;
    }

    private static string ScopeRowClass(bool active) =>
        (active
            ? "bg-accent-50 hover:bg-accent-100 "
            : "hover:bg-ink-50 ")
        + "w-full flex items-center gap-2.5 px-2 py-1.5 rounded-lg transition-colors";

    private IReadOnlyList<Domain.Models.Static.Spirit> OwnedSpiritsList() =>
        GameData.Spirits.Where(s => OwnedExpansions is null || OwnedExpansions.Contains(s.ExpansionId)).ToList();

    private IReadOnlyList<Domain.Models.Static.Adversary> OwnedAdversariesList() =>
        GameData.Adversaries.Where(a => OwnedExpansions is null || OwnedExpansions.Contains(a.ExpansionId)).ToList();

    private IReadOnlyList<Domain.Models.Static.Scenario> OwnedScenariosList() =>
        GameData.Scenarios.Where(s => OwnedExpansions is null || OwnedExpansions.Contains(s.ExpansionId)).ToList();

    private IReadOnlyList<Domain.Models.Static.Board> OwnedBoardsList() =>
        GameData.Boards.Where(b => OwnedExpansions is null || OwnedExpansions.Contains(b.ExpansionId)).ToList();

    private static List<MissingLevel> MissingAdversaryLevels(
        IReadOnlyList<Application.Features.Statistics.AdversaryStats> stats,
        IReadOnlyList<Domain.Models.Static.Adversary> ownedAdversaries)
    {
        var statsByAdv = stats.ToDictionary(a => a.AdversaryId);
        var missing = new List<MissingLevel>();
        foreach (var adv in ownedAdversaries)
        {
            var played = statsByAdv.TryGetValue(adv.Id.Value, out var s)
                ? s.Levels.Select(l => l.Level).ToHashSet()
                : new HashSet<int>();
            foreach (var mode in adv.Modes.OrderBy(m => m.Level))
            {
                if (!played.Contains(mode.Level))
                {
                    missing.Add(new MissingLevel(adv.Id.Value, adv.Name, mode.Level));
                }
            }
        }
        return missing;
    }

    private static string FormatHours(TimeSpan span)
    {
        var totalHours = span.TotalHours;
        if (totalHours >= 24)
        {
            var days = (int)(totalHours / 24);
            var hrs = (int)(totalHours - days * 24);
            return hrs > 0 ? $"{days}d {hrs}h" : $"{days}d";
        }
        return totalHours >= 1 ? $"{(int)totalHours}h" : $"{(int)span.TotalMinutes}m";
    }
}
