@page "/app/statistics"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser

<PageTitle>Statistics</PageTitle>

<div class="page-head">
    <div>
        <h1 class="page-title">Statistics</h1>
        <p class="page-sub">@(_scoped is not null ? $"Scoped to {_scoped.Name}." : "Your game history, distilled.")</p>
    </div>
    @if (_unfilteredPlayers.Count > 1)
    {
        <div class="relative">
            <button type="button" @onclick="ToggleScopePicker"
                    class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-ink-200 bg-white hover:bg-ink-50 transition-colors text-left
                           focus:outline-none focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30 min-w-[14rem]">
                @{
                    var scopedKind = _scoped?.Kind switch
                    {
                        Application.Features.Statistics.PlayerKind.Me => PlayerAssigneeBadge.AssigneeKind.Me,
                        Application.Features.Statistics.PlayerKind.Friend => PlayerAssigneeBadge.AssigneeKind.Friend,
                        Application.Features.Statistics.PlayerKind.Local => PlayerAssigneeBadge.AssigneeKind.Player,
                        _ => PlayerAssigneeBadge.AssigneeKind.Unknown,
                    };
                }
                @if (_scoped is null)
                {
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent-50 text-accent-700 shrink-0">
                        <Icon Name="users" Class="w-4 h-4"/>
                    </span>
                    <div class="min-w-0 flex-1">
                        <div class="text-sm font-medium text-ink-900">All players</div>
                        <div class="text-[10px] uppercase tracking-wide text-ink-500">Global stats</div>
                    </div>
                }
                else
                {
                    <PlayerAssigneeBadge Kind="scopedKind" Name="@_scoped.Name"
                                         DetailLabel="@($"{_scoped.GamesPlayed} games")"/>
                }
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none"
                     class="w-4 h-4 text-ink-400 shrink-0 ml-auto transition-transform @(_scopeOpen ? "rotate-180" : "")">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m6 8 4 4 4-4"/>
                </svg>
            </button>

            @if (_scopeOpen)
            {
                <div class="absolute z-30 mt-1 right-0 w-72 surface shadow-lg p-2 max-h-80 overflow-y-auto">
                    <button type="button" @onclick="() => SetScope(null)" class="@ScopeRowClass(_scoped is null)">
                        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent-50 text-accent-700 shrink-0">
                            <Icon Name="users" Class="w-4 h-4"/>
                        </span>
                        <div class="flex-1 text-left min-w-0">
                            <div class="text-sm font-medium text-ink-900 truncate">All players</div>
                            <div class="text-[10px] text-ink-500">Global stats across every recorded game</div>
                        </div>
                        @if (_scoped is null) { <Icon Name="check" Class="w-4 h-4 text-accent-700"/> }
                    </button>
                    <div class="my-1 border-t border-ink-100"></div>
                    @foreach (var p in _unfilteredPlayers)
                    {
                        var isSelected = SameScope(p, _scoped);
                        var rowKind = p.Kind switch
                        {
                            Application.Features.Statistics.PlayerKind.Me => PlayerAssigneeBadge.AssigneeKind.Me,
                            Application.Features.Statistics.PlayerKind.Friend => PlayerAssigneeBadge.AssigneeKind.Friend,
                            _ => PlayerAssigneeBadge.AssigneeKind.Player,
                        };
                        <button type="button" @onclick="() => SetScope(p)" class="@ScopeRowClass(isSelected)">
                            <PlayerAssigneeBadge Kind="rowKind" Name="@p.Name"
                                                 DetailLabel="@($"{p.GamesPlayed} games · {p.WinRate:F0}% win")"/>
                            @if (isSelected) { <Icon Name="check" Class="w-4 h-4 text-accent-700 ml-auto"/> }
                        </button>
                    }
                </div>
            }
        </div>
    }
</div>

@if (_loading)
{
    <LoadingSpinner/>
}
else if (_stats is null || _stats.TotalGames == 0)
{
    <div class="surface text-center py-16">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-ink-100 text-ink-500 mb-3">
            <Icon Name="chart" Class="w-5 h-5"/>
        </div>
        @if (_scoped is null)
        {
            <p class="text-ink-600">No statistics yet — record some games to see them here.</p>
            <a href="/app/games/new" class="btn btn-primary mt-4">Record a game</a>
        }
        else
        {
            <p class="text-ink-600">No games recorded with @_scoped.Name yet.</p>
            <button class="btn btn-secondary mt-4" @onclick="() => SetScope(null)">Clear filter</button>
        }
    </div>
}
else
{
    @* ============================== SCOPED PLAYER HEADER ============================== *@
    @if (_scoped is not null)
    {
        var favSpirit = _scoped.FavouriteSpirit is null ? null : GameLookups.SpiritFor(_scoped.FavouriteSpirit);
        var favDetail = favSpirit is null ? null : SpiritDetails.For(favSpirit.Id);
        var favColor = favDetail?.ColorHex ?? "#78716c";
        var headerKind = _scoped.Kind switch
        {
            Application.Features.Statistics.PlayerKind.Me => PlayerAssigneeBadge.AssigneeKind.Me,
            Application.Features.Statistics.PlayerKind.Friend => PlayerAssigneeBadge.AssigneeKind.Friend,
            _ => PlayerAssigneeBadge.AssigneeKind.Player,
        };
        <div class="surface px-5 py-4 mb-6 flex flex-wrap items-center gap-5">
            <PlayerAssigneeBadge Kind="headerKind" Name="@_scoped.Name"
                                 DetailLabel="@($"{_scoped.GamesPlayed} games recorded")"
                                 ContainerClass="inline-flex items-center gap-3 min-w-0 flex-1"/>
            <div class="flex items-center gap-4 ml-auto">
                <WinRateRing Pct="_scoped.WinRate" Size="64" Caption="win"/>
                @if (favSpirit is not null)
                {
                    <div class="flex items-center gap-2 min-w-0">
                        <span class="inline-block h-9 w-1.5 rounded-full shrink-0" style="background-color: @favColor;"></span>
                        <div class="min-w-0">
                            <div class="text-[10px] uppercase tracking-wide text-ink-500">Favourite spirit</div>
                            <div class="text-sm font-semibold text-ink-900 truncate">@favSpirit.Name</div>
                        </div>
                    </div>
                }
                <button class="btn btn-ghost btn-sm" @onclick="() => SetScope(null)">
                    <Icon Name="x" Class="w-3.5 h-3.5"/> Clear filter
                </button>
            </div>
        </div>
    }

    @* ============================== HERO STRIP ============================== *@
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 xl:grid-cols-6 gap-4 mb-2">
        <StatHero Value="@_stats.TotalGames.ToString()"
                  Label="Total games"
                  Caption="@($"{_stats.InProgress} in progress")"
                  Icon="controller"/>
        <StatHero Value="@($"{_stats.WinRate:F0}%")"
                  Label="Win rate"
                  Caption="@($"{_stats.Wins} W / {_stats.Losses} L")"
                  Icon="trophy"/>
        <StatHero Value="@($"{_stats.AverageScore:F0}")"
                  Label="Avg score"
                  Caption="@($"{_stats.AverageDifficulty:F1} avg difficulty")"
                  Icon="chart"/>
        <StatHero Value="@_stats.BestScore.ToString()"
                  Label="Best score"
                  Caption="@(_stats.BestScoreGameId is not null ? "View that match →" : "—")"
                  Icon="star"
                  Href="@(_stats.BestScoreGameId is { } id ? $"/app/games/{id}" : null)"/>
        <StatHero Value="@FormatHours(_stats.TotalPlayTime)"
                  Label="Time played"
                  Caption="@($"avg {_stats.AverageDuration:h\\:mm} per game")"
                  Icon="clock"/>
        <StatHero Value="@(_stats.LongestStreak > 0 ? _stats.LongestStreak.ToString() : "—")"
                  Label="Best streak"
                  Caption="consecutive wins"
                  Icon="sparkles"/>
    </div>
    <div class="grid grid-cols-3 gap-4 mb-6">
        <StatHero Value="@(_stats.MinScore?.ToString() ?? "—")"
                  Label="Lowest score"
                  Caption="completed games"
                  Icon="chart"/>
        <StatHero Value="@($"{_stats.AverageDahan:F1}")"
                  Label="Avg dahan"
                  Caption="alive at game end"
                  Icon="users"/>
        <StatHero Value="@($"{_stats.AverageBlight:F1}")"
                  Label="Avg blight"
                  Caption="on island at game end"
                  Icon="shield"/>
    </div>

    @* ============================== TABS ============================== *@
    <div class="flex items-center gap-1 border-b border-ink-200 mb-6 overflow-x-auto">
        @foreach (var t in _tabs)
        {
            <button @onclick="() => SetTab(t.Key)" class="@TabClass(t.Key)">@t.Label</button>
        }
    </div>

    @switch (_tab)
    {
        case "overview":
            @OverviewTab();
            break;
        case "spirits":
            @SpiritsTab();
            break;
        case "adversaries":
            @AdversariesTab();
            break;
        case "scenarios":
            @ScenariosTab();
            break;
        case "boards":
            @BoardsTab();
            break;
    }
}

@* ============================== OVERVIEW TAB ============================== *@
@code {
    private RenderFragment OverviewTab() =>
        @<div class="space-y-6">
            @{
                var topSpirit = _stats!.SpiritStatistics.OrderByDescending(s => s.GamesPlayed).FirstOrDefault();
                var bestSpirit = _stats.SpiritStatistics.Where(s => s.GamesPlayed >= 3).OrderByDescending(s => s.WinRate).FirstOrDefault();
                var toughAdv = _stats.AdversaryStatistics.Where(a => a.GamesPlayed >= 3).OrderBy(a => a.WinRate).FirstOrDefault();
                var favAdv = _stats.AdversaryStatistics.OrderByDescending(a => a.GamesPlayed).FirstOrDefault();
                var topBoard = _stats.BoardStatistics.OrderByDescending(b => b.GamesPlayed).FirstOrDefault();
                var topScenario = _stats.ScenarioStatistics.OrderByDescending(s => s.GamesPlayed).FirstOrDefault();
            }

            @* ===== Outcome donut + Highlights row ===== *@
            <div class="grid lg:grid-cols-3 gap-6">
                @* Outcome donut card *@
                <div class="surface px-5 py-5">
                    <h2 class="text-base font-semibold mb-3" style="font-family: var(--font-serif);">Outcome</h2>
                    <div class="flex items-center justify-between gap-4">
                        <WinRateRing Pct="_stats.WinRate" Size="128" Stroke="12" Caption="win rate"/>
                        <div class="space-y-2 text-sm flex-1 min-w-0">
                            <div class="flex items-center justify-between gap-2">
                                <span class="inline-flex items-center gap-2 text-ink-700"><span class="h-2.5 w-2.5 rounded-full bg-accent-500"></span>Wins</span>
                                <span class="font-semibold tabular-nums text-ink-900">@_stats.Wins</span>
                            </div>
                            <div class="flex items-center justify-between gap-2">
                                <span class="inline-flex items-center gap-2 text-ink-700"><span class="h-2.5 w-2.5 rounded-full bg-red-300"></span>Losses</span>
                                <span class="font-semibold tabular-nums text-ink-900">@_stats.Losses</span>
                            </div>
                            <div class="flex items-center justify-between gap-2 pt-2 border-t border-ink-100">
                                <span class="inline-flex items-center gap-2 text-ink-500 text-xs">In progress</span>
                                <span class="font-medium tabular-nums text-ink-700">@_stats.InProgress</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* Highlights stack — two highlights *@
                <div class="space-y-3">
                    @if (topSpirit is not null)
                    {
                        var sp = GameLookups.SpiritFor(topSpirit.SpiritId);
                        var color = (sp is null ? null : SpiritDetails.For(sp.Id))?.ColorHex;
                        <InsightCard Title="Most played spirit"
                                     Subject="@(sp?.Name ?? topSpirit.SpiritId)"
                                     Secondary="@($"{topSpirit.WinRate:F0}% win · {topSpirit.AverageScore:F0} avg score")"
                                     Metric="@topSpirit.GamesPlayed.ToString()"
                                     MetricLabel="games"
                                     AccentColor="@color"/>
                    }
                    @if (bestSpirit is not null && bestSpirit.SpiritId != topSpirit?.SpiritId)
                    {
                        var sp = GameLookups.SpiritFor(bestSpirit.SpiritId);
                        var color = (sp is null ? null : SpiritDetails.For(sp.Id))?.ColorHex;
                        <InsightCard Title="Highest win rate"
                                     Subject="@(sp?.Name ?? bestSpirit.SpiritId)"
                                     Secondary="@($"{bestSpirit.GamesPlayed} games")"
                                     Metric="@($"{bestSpirit.WinRate:F0}%")"
                                     MetricLabel="wins"
                                     MetricColorClass="text-accent-700"
                                     AccentColor="@color"/>
                    }
                </div>

                @* Highlights stack — adversary side *@
                <div class="space-y-3">
                    @if (favAdv is not null)
                    {
                        var adv = GameLookups.AdversaryFor(favAdv.AdversaryId);
                        <InsightCard Title="Most played adversary"
                                     Subject="@(adv?.Name ?? favAdv.AdversaryId)"
                                     Secondary="@($"avg L{favAdv.AverageLevel:F1} · {favAdv.WinRate:F0}% win")"
                                     Metric="@favAdv.GamesPlayed.ToString()"
                                     MetricLabel="games"/>
                    }
                    @if (toughAdv is not null && toughAdv.AdversaryId != favAdv?.AdversaryId)
                    {
                        var adv = GameLookups.AdversaryFor(toughAdv.AdversaryId);
                        <InsightCard Title="Toughest matchup"
                                     Subject="@(adv?.Name ?? toughAdv.AdversaryId)"
                                     Secondary="@($"{toughAdv.GamesPlayed} games")"
                                     Metric="@($"{toughAdv.WinRate:F0}%")"
                                     MetricLabel="wins"
                                     MetricColorClass="text-red-700"/>
                    }
                </div>
            </div>

            @* ===== Recent games ===== *@
            <div>
                <div class="flex items-baseline justify-between mb-3">
                    <h2 class="text-base font-semibold" style="font-family: var(--font-serif);">Recent games</h2>
                    <a href="/app/games" class="text-xs text-accent-700 hover:underline">View all →</a>
                </div>
                <RecentGamesStrip Games="_stats.RecentGames"/>
            </div>

            @* ===== Activity chart full width ===== *@
            <div class="surface px-5 pt-5 pb-3">
                <div class="flex items-baseline justify-between mb-3">
                    <h2 class="text-base font-semibold" style="font-family: var(--font-serif);">Activity over time</h2>
                    <span class="text-[11px] text-ink-500">Wins vs losses per month</span>
                </div>
                <MonthlyGamesChart Months="_stats.MonthlyStatistics" Height="280"/>
            </div>

            @* ===== Distributions ===== *@
            <div class="grid lg:grid-cols-2 gap-6">
                <div class="surface px-5 pt-5 pb-3">
                    <div class="flex items-baseline justify-between mb-3">
                        <h2 class="text-base font-semibold" style="font-family: var(--font-serif);">Score distribution</h2>
                        <span class="text-[11px] text-ink-500">@_stats.CompletedScores.Count completed games</span>
                    </div>
                    <ScoreDistributionChart Scores="_stats.CompletedScores"/>
                </div>
                <div class="surface px-5 pt-5 pb-3">
                    <div class="flex items-baseline justify-between mb-3">
                        <h2 class="text-base font-semibold" style="font-family: var(--font-serif);">Difficulty distribution</h2>
                        <span class="text-[11px] text-ink-500">avg @($"{_stats.AverageDifficulty:F1}")</span>
                    </div>
                    <DifficultyDistributionChart Difficulties="_stats.CompletedDifficulties"/>
                </div>
            </div>
        </div>;
}

@* ============================== SPIRITS TAB ============================== *@
@code {
    private RenderFragment SpiritsTab() =>
        @<div class="space-y-6">
            @{
                var topSpirit = _stats!.SpiritStatistics.OrderByDescending(s => s.GamesPlayed).FirstOrDefault();
                var bestScoreSpirit = _stats.SpiritStatistics.Where(s => s.BestScore.HasValue).OrderByDescending(s => s.BestScore!.Value).FirstOrDefault();
                var bestRateSpirit = _stats.SpiritStatistics.Where(s => s.GamesPlayed >= 3).OrderByDescending(s => s.WinRate).FirstOrDefault();
                var playedSpiritIds = _stats.SpiritStatistics.Select(s => s.SpiritId).ToHashSet();
                var ownedSpirits = OwnedSpiritsList();
                var missingSpirits = ownedSpirits.Where(s => !playedSpiritIds.Contains(s.Id.Value)).Cast<object>().ToList();
            }

            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                @if (topSpirit is not null) { @SpiritInsight("Most played", topSpirit, $"{topSpirit.GamesPlayed} games") }
                @if (bestRateSpirit is not null) { @SpiritInsight("Highest win rate", bestRateSpirit, $"{bestRateSpirit.WinRate:F0}%") }
                @if (bestScoreSpirit is not null) { @SpiritInsight("Highest score", bestScoreSpirit, $"{bestScoreSpirit.BestScore} pts") }
            </div>

            <div class="surface px-5 pt-5 pb-3">
                <div class="flex items-baseline justify-between mb-3">
                    <h2 class="text-base font-semibold" style="font-family: var(--font-serif);">Games played by spirit</h2>
                </div>
                <SpiritGamesChart Spirits="_stats.SpiritStatistics"/>
            </div>

            <div class="surface">
                <div class="surface-head"><h2 class="text-base font-semibold">All spirits</h2></div>
                <div class="table-wrap">
                    <table class="table">
                        <thead><tr>
                            <th>Spirit</th>
                            <th class="text-right">Games</th>
                            <th class="text-right">W</th>
                            <th class="text-right">L</th>
                            <th>Win rate</th>
                            <th class="text-right">Avg score</th>
                            <th class="text-right">Best</th>
                        </tr></thead>
                        <tbody>
                        @foreach (var s in _stats.SpiritStatistics)
                        {
                            var spirit = GameLookups.SpiritFor(s.SpiritId);
                            var detail = spirit is null ? null : SpiritDetails.For(spirit.Id);
                            var color = detail?.ColorHex ?? "#78716c";
                            <tr>
                                <td>
                                    <div class="flex items-center gap-3 min-w-0">
                                        <span class="inline-block h-8 w-1.5 rounded-full shrink-0" style="background-color: @color;"></span>
                                        <div class="min-w-0">
                                            <div class="text-sm font-semibold text-ink-900 truncate">@(spirit?.Name ?? s.SpiritId)</div>
                                            @if (detail is not null) { <div class="text-[11px] text-ink-500 truncate">@detail.PlayStyle</div> }
                                        </div>
                                    </div>
                                </td>
                                <td class="text-right tabular-nums">@s.GamesPlayed</td>
                                <td class="text-right text-accent-700 tabular-nums">@s.Wins</td>
                                <td class="text-right text-red-600 tabular-nums">@s.Losses</td>
                                <td><WinRateBar Pct="s.WinRate"/></td>
                                <td class="text-right tabular-nums">@($"{s.AverageScore:F0}")</td>
                                <td class="text-right tabular-nums">@(s.BestScore?.ToString() ?? "—")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <CoveragePanel Title="Spirits" Total="ownedSpirits.Count" Missing="missingSpirits" ItemTemplate="SpiritPill"/>
        </div>;

    private RenderFragment<object> SpiritPill => o =>
        @<text>
            @{
                var spirit = (Domain.Models.Static.Spirit)o;
                var detail = SpiritDetails.For(spirit.Id);
                var color = detail?.ColorHex ?? "#78716c";
            }
            <span class="inline-flex items-center gap-1.5 rounded-full border border-ink-200 bg-white px-2.5 py-1 text-xs">
                <span class="inline-block h-2 w-2 rounded-full" style="background-color: @color;"></span>
                <span class="text-ink-700">@spirit.Name</span>
            </span>
        </text>;

    private RenderFragment SpiritInsight(string title, Application.Features.Statistics.SpiritStats s, string metric) =>
        @<text>
            @{
                var sp = GameLookups.SpiritFor(s.SpiritId);
                var detail = sp is null ? null : SpiritDetails.For(sp.Id);
                var color = detail?.ColorHex;
            }
            <InsightCard Title="@title"
                         Subject="@(sp?.Name ?? s.SpiritId)"
                         Secondary="@($"{s.GamesPlayed} games · {s.AverageScore:F0} avg")"
                         Metric="@metric"
                         AccentColor="@color"/>
        </text>;
}

@* ============================== ADVERSARIES TAB ============================== *@
@code {
    private RenderFragment AdversariesTab() =>
        @<div class="space-y-6">
            @{
                var topAdv = _stats!.AdversaryStatistics.OrderByDescending(a => a.GamesPlayed).FirstOrDefault();
                var bestAdv = _stats.AdversaryStatistics.Where(a => a.GamesPlayed >= 3).OrderByDescending(a => a.WinRate).FirstOrDefault();
                var worstAdv = _stats.AdversaryStatistics.Where(a => a.GamesPlayed >= 3).OrderBy(a => a.WinRate).FirstOrDefault();
                var ownedAdversaries = OwnedAdversariesList();
                var missingLevels = MissingAdversaryLevels(_stats.AdversaryStatistics, ownedAdversaries);
                var missingGroups = missingLevels
                    .GroupBy(m => (m.AdversaryId, m.AdversaryName))
                    .OrderBy(g => g.Key.AdversaryName)
                    .Select(g => new MissingAdversaryGroup(g.Key.AdversaryId, g.Key.AdversaryName, g.Select(m => m.Level).OrderBy(l => l).ToList()))
                    .Cast<object>().ToList();
                var totalLevels = ownedAdversaries.Sum(a => a.Modes.Count());
            }

            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                @if (topAdv is not null) { @AdversaryInsight("Most played", topAdv, $"{topAdv.GamesPlayed} games", null) }
                @if (bestAdv is not null) { @AdversaryInsight("Highest win rate", bestAdv, $"{bestAdv.WinRate:F0}%", "text-accent-700") }
                @if (worstAdv is not null && worstAdv.AdversaryId != bestAdv?.AdversaryId) { @AdversaryInsight("Toughest", worstAdv, $"{worstAdv.WinRate:F0}%", "text-red-700") }
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
                @foreach (var a in _stats.AdversaryStatistics)
                {
                    var adv = GameLookups.AdversaryFor(a.AdversaryId);
                    var allLevels = adv?.Modes.Select(m => m.Level).OrderBy(l => l).ToList() ?? a.Levels.Select(l => l.Level).ToList();
                    <div class="surface px-5 py-4">
                        <div class="flex items-start justify-between gap-3 mb-3">
                            <div class="min-w-0">
                                <div class="text-base font-semibold text-ink-900 truncate" style="font-family: var(--font-serif);">@(adv?.Name ?? a.AdversaryId)</div>
                                <div class="text-[11px] text-ink-500 mt-0.5">
                                    @a.GamesPlayed games · @a.Wins W / @a.Losses L · avg L@(a.AverageLevel.ToString("F1"))
                                </div>
                            </div>
                            <WinRateRing Pct="a.WinRate" Size="56"/>
                        </div>
                        <AdversaryLevelChart Levels="a.Levels" AllLevels="allLevels"/>
                    </div>
                }
            </div>

            <CoveragePanel Title="Adversary levels"
                           Total="totalLevels"
                           Missing="missingGroups"
                           MissingCount="missingLevels.Count"
                           ItemTemplate="AdversaryLevelGroupPill"/>
        </div>;

    private RenderFragment<object> AdversaryLevelGroupPill => o =>
        @<text>
            @{
                var entry = (MissingAdversaryGroup)o;
            }
            <span class="inline-flex items-center gap-1.5 rounded-full border border-ink-200 bg-white px-2.5 py-1 text-xs">
                <Icon Name="shield" Class="w-3 h-3 text-ink-400"/>
                <span class="text-ink-700 font-medium">@entry.AdversaryName</span>
                <span class="text-ink-500">@string.Join(", ", entry.Levels.Select(l => $"L{l}"))</span>
            </span>
        </text>;

    private RenderFragment AdversaryInsight(string title, Application.Features.Statistics.AdversaryStats a, string metric, string? metricColor) =>
        @<text>
            @{
                var adv = GameLookups.AdversaryFor(a.AdversaryId);
            }
            <InsightCard Title="@title"
                         Subject="@(adv?.Name ?? a.AdversaryId)"
                         Secondary="@($"avg L{a.AverageLevel:F1}")"
                         Metric="@metric"
                         MetricColorClass="@(metricColor ?? "text-ink-900")"/>
        </text>;
}

@* ============================== SCENARIOS TAB ============================== *@
@code {
    private RenderFragment ScenariosTab() =>
        @<div class="space-y-6">
            @{
                var topScen = _stats!.ScenarioStatistics.OrderByDescending(s => s.GamesPlayed).FirstOrDefault();
                var bestScen = _stats.ScenarioStatistics.Where(s => s.GamesPlayed >= 3).OrderByDescending(s => s.WinRate).FirstOrDefault();
                var playedIds = _stats.ScenarioStatistics.Select(s => s.ScenarioId).ToHashSet();
                var ownedScenarios = OwnedScenariosList();
                var missing = ownedScenarios.Where(s => !playedIds.Contains(s.Id.Value)).Cast<object>().ToList();
            }

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                @if (topScen is not null)
                {
                    var s = GameLookups.ScenarioFor(topScen.ScenarioId);
                    <InsightCard Title="Most played scenario" Subject="@(s?.Name ?? topScen.ScenarioId)"
                                 Secondary="@($"{topScen.WinRate:F0}% win · {topScen.AverageScore:F0} avg")"
                                 Metric="@topScen.GamesPlayed.ToString()" MetricLabel="games"/>
                }
                @if (bestScen is not null && bestScen.ScenarioId != topScen?.ScenarioId)
                {
                    var s = GameLookups.ScenarioFor(bestScen.ScenarioId);
                    <InsightCard Title="Highest win rate" Subject="@(s?.Name ?? bestScen.ScenarioId)"
                                 Secondary="@($"{bestScen.GamesPlayed} games")"
                                 Metric="@($"{bestScen.WinRate:F0}%")" MetricColorClass="text-accent-700"/>
                }
            </div>

            @if (_stats.ScenarioStatistics.Count > 0)
            {
                <div class="surface">
                    <div class="surface-head"><h2 class="text-base font-semibold">All scenarios played</h2></div>
                    <div class="table-wrap">
                        <table class="table">
                            <thead><tr><th>Scenario</th><th class="text-right">Games</th><th class="text-right">W</th><th class="text-right">L</th><th>Win rate</th><th class="text-right">Avg score</th></tr></thead>
                            <tbody>
                            @foreach (var s in _stats.ScenarioStatistics)
                            {
                                var sc = GameLookups.ScenarioFor(s.ScenarioId);
                                <tr>
                                    <td>
                                        <div class="flex items-center gap-2 min-w-0">
                                            <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-accent-50 text-accent-700 shrink-0"><Icon Name="book" Class="w-3.5 h-3.5"/></span>
                                            <span class="text-sm font-semibold text-ink-900 truncate">@(sc?.Name ?? s.ScenarioId)</span>
                                        </div>
                                    </td>
                                    <td class="text-right tabular-nums">@s.GamesPlayed</td>
                                    <td class="text-right text-accent-700 tabular-nums">@s.Wins</td>
                                    <td class="text-right text-red-600 tabular-nums">@s.Losses</td>
                                    <td><WinRateBar Pct="s.WinRate"/></td>
                                    <td class="text-right tabular-nums">@($"{s.AverageScore:F0}")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <CoveragePanel Title="Scenarios" Total="ownedScenarios.Count" Missing="missing" ItemTemplate="ScenarioPill"/>
        </div>;

    private RenderFragment<object> ScenarioPill => o =>
        @<text>
            @{ var s = (Domain.Models.Static.Scenario)o; }
            <span class="inline-flex items-center gap-1.5 rounded-full border border-ink-200 bg-white px-2.5 py-1 text-xs">
                <Icon Name="book" Class="w-3 h-3 text-ink-400"/>
                <span class="text-ink-700">@s.Name</span>
                <span class="text-ink-500">+@s.Difficulty</span>
            </span>
        </text>;
}

