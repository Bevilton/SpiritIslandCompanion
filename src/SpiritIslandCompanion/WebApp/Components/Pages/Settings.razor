@page "/app/settings"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject WebApp.State.OwnedExpansionsState ExpansionsState

<PageTitle>Settings</PageTitle>

<div class="page-head">
    <div>
        <h1 class="page-title">Settings</h1>
        <p class="page-sub">Configure your collection and preferences.</p>
    </div>
</div>

<Alert Message="@_message" Type="@_alertType"/>

@if (_loading)
{
    <LoadingSpinner/>
}
else
{
    <section class="surface max-w-2xl">
        <div class="surface-head">
            <h2 class="text-base font-semibold">Owned expansions</h2>
        </div>
        <div class="surface-body">
            <p class="text-sm text-ink-500 mb-5">
                Pick the expansions you own — content throughout the app filters to match. The base game is always included.
            </p>
            <div class="space-y-2">
                @foreach (var expansion in GameData.Expansions)
                {
                    var isBase = expansion.Id == Expansions.BaseGame;
                    var isOwned = isBase || _ownedExpansions.Contains(expansion.Id.Value);
                    var counts = _counts[expansion.Id.Value];
                    <label for="@($"exp-{expansion.Id.Value}")"
                           class="flex items-center justify-between p-3 rounded-lg border @(isOwned ? "border-accent-300 bg-accent-50/40" : "border-ink-200 bg-white") @(isBase ? "" : "cursor-pointer hover:border-accent-300") transition-colors">
                        <div class="flex items-center gap-3">
                            <input class="checkbox" type="checkbox"
                                   id="@($"exp-{expansion.Id.Value}")"
                                   checked="@isOwned"
                                   disabled="@isBase"
                                   @onchange="e => ToggleExpansion(expansion.Id.Value, (bool)(e.Value ?? false))"/>
                            <div>
                                <div class="font-medium text-ink-900 flex items-center gap-2">
                                    @expansion.Name
                                    @if (isBase)
                                    {
                                        <span class="badge badge-neutral">Required</span>
                                    }
                                </div>
                                <div class="text-xs text-ink-500 mt-0.5">@counts.Spirits spirits · @counts.Adversaries adversaries · @counts.Scenarios scenarios</div>
                            </div>
                        </div>
                    </label>
                }
            </div>
        </div>
        <div class="surface-foot">
            <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                @if (_saving)
                {
                    <span class="inline-flex h-3.5 w-3.5 animate-spin rounded-full border-2 border-white/40 border-t-white"></span>
                }
                else
                {
                    <Icon Name="check" Class="w-4 h-4"/>
                }
                Save
            </button>
        </div>
    </section>
}

@code {
    private HashSet<string> _ownedExpansions = [];
    private bool _loading = true;
    private bool _saving;
    private string? _message;
    private string _alertType = "success";

    private record ExpansionCounts(int Spirits, int Adversaries, int Scenarios);

    private static readonly Dictionary<string, ExpansionCounts> _counts =
        GameData.Expansions.ToDictionary(
            e => e.Id.Value,
            e => new ExpansionCounts(
                GameData.Spirits.Count(s => s.ExpansionId == e.Id),
                GameData.Adversaries.Count(a => a.ExpansionId == e.Id),
                GameData.Scenarios.Count(s => s.ExpansionId == e.Id)));

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser.UserId is not { } userId) return;
        var result = await Mediator.Send(new Application.Features.Users.GetUserQuery(userId));
        if (result.IsSuccess)
            _ownedExpansions = result.Value.OwnedExpansionIds.ToHashSet();
        _ownedExpansions.Add(Expansions.BaseGame.Value);
        _loading = false;
    }

    private void ToggleExpansion(string id, bool isChecked)
    {
        if (id == Expansions.BaseGame.Value) return;
        if (isChecked) _ownedExpansions.Add(id);
        else _ownedExpansions.Remove(id);
    }

    private async Task Save()
    {
        _saving = true;
        _ownedExpansions.Add(Expansions.BaseGame.Value);
        var result = await Mediator.Send(new Application.Features.Users.UpdateUserSettingsCommand(
            CurrentUser.UserId!.Value, _ownedExpansions.ToList()));
        _saving = false;

        if (result.IsSuccess)
        {
            _message = "Settings saved.";
            _alertType = "success";
            await ExpansionsState.ReloadAsync();
        }
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }
}
