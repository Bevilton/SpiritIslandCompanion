@page "/app/friends"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser

<PageTitle>Friends</PageTitle>

<div class="page-head">
    <div>
        <h1 class="page-title">Friends</h1>
        <p class="page-sub">Connect with players who have their own account.</p>
    </div>
</div>

<Alert Message="@_message" Type="@_alertType"/>
<FormErrorSummary Errors="@_errors"/>

@if (_loading)
{
    <LoadingSpinner/>
}
else
{
    <section class="surface mb-5">
        <div class="surface-head"><h2 class="text-base font-semibold">Send a friend request</h2></div>
        <div class="surface-body">
            <div class="flex flex-col sm:flex-row gap-2 max-w-xl">
                <div class="flex-1">
                    <input type="email" class="input w-full" placeholder="friend@example.com"
                           @bind="_friendEmail" @bind:event="oninput"/>
                    <FieldError For="AddresseeEmail" Errors="@_errors"/>
                </div>
                <button class="btn btn-primary self-start" @onclick="SendRequest" disabled="@string.IsNullOrWhiteSpace(_friendEmail)">
                    <Icon Name="send" Class="w-4 h-4"/> Send
                </button>
            </div>
        </div>
    </section>

    @if (_pending?.Incoming.Count > 0)
    {
        <section class="surface mb-5">
            <div class="surface-head">
                <h2 class="text-base font-semibold inline-flex items-center gap-2">
                    Incoming requests
                    <span class="badge badge-info">@_pending.Incoming.Count</span>
                </h2>
            </div>
            <ul class="divide-y divide-ink-100">
                @foreach (var r in _pending.Incoming)
                {
                    <li class="px-5 md:px-6 py-3 flex items-center justify-between gap-4">
                        <div class="min-w-0">
                            <div class="font-medium text-ink-900 truncate">@r.Nickname</div>
                            <div class="text-xs text-ink-500 truncate">@r.Email · @r.SentAt.LocalDateTime.ToString("MMM dd")</div>
                        </div>
                        <div class="flex gap-2 shrink-0">
                            <button class="btn btn-sm btn-primary" @onclick="() => AcceptRequest(r.FriendshipId)">
                                <Icon Name="check" Class="w-3.5 h-3.5"/> Accept
                            </button>
                            <button class="btn btn-sm btn-danger-outline" @onclick="() => RejectRequest(r.FriendshipId)">
                                <Icon Name="x" Class="w-3.5 h-3.5"/> Reject
                            </button>
                        </div>
                    </li>
                }
            </ul>
        </section>
    }

    @if (_pending?.Outgoing.Count > 0)
    {
        <section class="surface mb-5">
            <div class="surface-head"><h2 class="text-base font-semibold">Sent requests</h2></div>
            <ul class="divide-y divide-ink-100">
                @foreach (var r in _pending.Outgoing)
                {
                    <li class="px-5 md:px-6 py-3 flex items-center justify-between gap-4">
                        <div class="min-w-0">
                            <div class="font-medium text-ink-900 truncate">@r.Nickname</div>
                            <div class="text-xs text-ink-500 truncate">@r.Email</div>
                        </div>
                        <span class="badge badge-neutral">Pending</span>
                    </li>
                }
            </ul>
        </section>
    }

    <section class="surface">
        <div class="surface-head"><h2 class="text-base font-semibold">Your friends</h2></div>
        @if (_friends.Count == 0)
        {
            <div class="px-6 py-12 text-center text-ink-500">No friends yet — send a request to get started.</div>
        }
        else
        {
            <ul class="divide-y divide-ink-100">
                @foreach (var f in _friends)
                {
                    <li class="px-5 md:px-6 py-3 flex items-center justify-between gap-4">
                        <div class="flex items-center gap-3 min-w-0">
                            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent-100 text-accent-800 text-sm font-medium shrink-0">
                                @(string.IsNullOrEmpty(f.Nickname) ? "?" : char.ToUpperInvariant(f.Nickname[0]).ToString())
                            </span>
                            <div class="min-w-0">
                                <div class="font-medium text-ink-900 truncate">@f.Nickname</div>
                                <div class="text-xs text-ink-500 truncate">@f.Email</div>
                            </div>
                        </div>
                        <button class="btn btn-sm btn-danger-outline" @onclick="() => RemoveFriend(f.FriendshipId)">
                            <Icon Name="trash" Class="w-3.5 h-3.5"/>
                        </button>
                    </li>
                }
            </ul>
        }
    </section>

    <ConfirmDialog @ref="_confirmDialog" Title="Remove friend" Message="Are you sure you want to remove this friend?"/>
}

@code {
    private List<Application.Features.Friendships.FriendResponse> _friends = [];
    private Application.Features.Friendships.PendingRequestsResponse? _pending;
    private bool _loading = true;
    private string _friendEmail = "";
    private string? _message;
    private string _alertType = "success";
    private FormErrors _errors = FormErrors.Empty;
    private ConfirmDialog _confirmDialog = default!;

    private void HandleResult(Domain.Results.Result result, string successMessage, string successAlertType = "success")
    {
        _errors = FormErrors.FromResult(result);
        if (result.IsSuccess)
        {
            _message = successMessage;
            _alertType = successAlertType;
        }
        else if (_errors.Any)
        {
            _message = null;
        }
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        if (CurrentUser.UserId is not { } userId) return;

        var friendsResult = await Mediator.Send(new Application.Features.Friendships.ListFriendsQuery(userId));
        var pendingResult = await Mediator.Send(new Application.Features.Friendships.ListPendingRequestsQuery(userId));

        if (friendsResult.IsSuccess) _friends = friendsResult.Value;
        if (pendingResult.IsSuccess) _pending = pendingResult.Value;

        _loading = false;
    }

    private async Task SendRequest()
    {
        var email = _friendEmail;
        var result = await Mediator.Send(new Application.Features.Friendships.SendFriendRequestCommand(
            CurrentUser.UserId!.Value, _friendEmail));

        HandleResult(result, $"Friend request sent to {email}!");
        if (result.IsSuccess)
        {
            _friendEmail = "";
            await LoadData();
        }
    }

    private async Task AcceptRequest(Guid friendshipId)
    {
        var result = await Mediator.Send(new Application.Features.Friendships.AcceptFriendRequestCommand(
            friendshipId, CurrentUser.UserId!.Value));
        HandleResult(result, "Friend request accepted.");
        await LoadData();
    }

    private async Task RejectRequest(Guid friendshipId)
    {
        var result = await Mediator.Send(new Application.Features.Friendships.RejectFriendRequestCommand(
            friendshipId, CurrentUser.UserId!.Value));
        HandleResult(result, "Friend request rejected.", "info");
        await LoadData();
    }

    private async Task RemoveFriend(Guid friendshipId)
    {
        if (!await _confirmDialog.ShowAsync()) return;

        var result = await Mediator.Send(new Application.Features.Friendships.RemoveFriendCommand(
            friendshipId, CurrentUser.UserId!.Value));
        HandleResult(result, "Friend removed.", "info");
        await LoadData();
    }
}
