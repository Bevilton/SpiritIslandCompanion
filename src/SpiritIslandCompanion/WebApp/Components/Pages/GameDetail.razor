@page "/app/games/{Id:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>Game Detail</PageTitle>

@if (_loading)
{
    <LoadingSpinner/>
}
else if (_game is null)
{
    <div class="alert alert-warn">
        <Icon Name="x" Class="w-5 h-5"/>
        <div>Game not found.</div>
    </div>
}
else
{
    <div class="page-head">
        <div>
            <a href="/app/games" class="text-sm text-ink-500 hover:text-ink-700 flex w-fit items-center gap-1 mb-2">
                <Icon Name="arrow-left" Class="w-3.5 h-3.5"/> Games
            </a>
            <span class="eyebrow">@(_game.IsCompleted ? "Recorded match" : "Draft")</span>
            <h1 class="page-title mt-2">@_game.StartedAt.LocalDateTime.ToString("MMMM dd, yyyy")</h1>
            <div class="mt-2"><GameStatusBadge IsCompleted="_game.IsCompleted" Win="_game.Result?.Win"/></div>
        </div>
        <div class="flex flex-wrap gap-2">
            @if (!_game.IsCompleted && !_showCompleteForm)
            {
                <button class="btn btn-primary" @onclick="StartComplete">
                    <Icon Name="check-circle" Class="w-4 h-4"/> Complete game
                </button>
            }
            <button class="btn btn-danger-outline" @onclick="DeleteGame">
                <Icon Name="trash" Class="w-4 h-4"/> Delete
            </button>
        </div>
    </div>

    <Alert Message="@_message" Type="@_alertType"/>
    <FormErrorSummary Errors="@_errors"/>

    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-6">
        <div class="lg:min-w-0 space-y-8">
            @* ============================== SETUP ============================== *@
            <section>
                <div class="flex items-end justify-between mb-3">
                    <h2 class="text-xl font-semibold" style="font-family: var(--font-serif);">Setup</h2>
                </div>
                <GameSetupSummary
                    IslandSetupId="@_game.IslandSetupId"
                    ExtraBoard="_game.ExtraBoard"
                    ThematicMaps="_game.ThematicMaps"
                    Difficulty="_game.Difficulty"
                    DifficultyModifier="_game.DifficultyModifier"
                    ScenarioId="@_game.ScenarioId"
                    Adversaries="_game.Adversaries"/>
            </section>

            @* ============================== PLAYERS ============================== *@
            <section>
                <div class="flex items-end justify-between mb-3">
                    <h2 class="text-xl font-semibold" style="font-family: var(--font-serif);">
                        Players <span class="text-ink-500 font-normal text-base">· @_game.Players.Count</span>
                    </h2>
                </div>
                <div class="grid gap-3">
                    @for (var i = 0; i < _game.Players.Count; i++)
                    {
                        <GamePlayerCard
                            Player="_game.Players[i]"
                            Index="i"
                            CurrentUserId="CurrentUser.UserId"
                            Friends="_friends"
                            LocalPlayers="_localPlayers"/>
                    }
                </div>
            </section>

            @* ============================== OUTCOME ============================== *@
            <section>
                <div class="flex items-end justify-between mb-3">
                    <h2 class="text-xl font-semibold" style="font-family: var(--font-serif);">Outcome</h2>
                </div>

                @if (_showCompleteForm)
                {
                    <div class="rounded-2xl border border-amber-300 bg-gradient-to-br from-amber-50 via-white to-amber-50/40 shadow-sm p-5 md:p-6">
                        <div class="flex items-center gap-3 mb-5">
                            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 text-amber-700">
                                <Icon Name="trophy" Class="w-5 h-5"/>
                            </span>
                            <div>
                                <div class="text-sm font-semibold text-ink-900">Record the result</div>
                                <div class="text-xs text-ink-500">Save the outcome to turn this draft into a completed match.</div>
                            </div>
                        </div>
                        <GameResultEditor
                            Difficulty="_game.Difficulty"
                            PlayerCount="_game.Players.Count"
                            Errors="_errors"
                            Win="_resultWin" WinChanged="v => _resultWin = v"
                            TerrorLevel="_resultTerror" TerrorLevelChanged="v => _resultTerror = v"
                            DurationMinutes="_resultDurationMinutes" DurationMinutesChanged="v => _resultDurationMinutes = v"
                            Dahan="_resultDahan" DahanChanged="v => _resultDahan = v"
                            Blight="_resultBlight" BlightChanged="v => _resultBlight = v"
                            Cards="_resultCards" CardsChanged="v => _resultCards = v"
                            ScoreModifier="_resultScoreModifier" ScoreModifierChanged="v => _resultScoreModifier = v"/>
                        <div class="mt-5">
                            <label class="label">Note</label>
                            <textarea class="textarea" rows="3" @bind="_resultNote"
                                      placeholder="Optional — anything memorable from the match"></textarea>
                            <FieldError For="Note" Errors="@_errors"/>
                        </div>
                    </div>
                }
                else if (_game.Result is not null)
                {
                    <GameResultSummary Result="_game.Result"/>
                }
                else
                {
                    <div class="rounded-2xl border-2 border-dashed border-ink-300 bg-ink-50/40 p-8 text-center">
                        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-white border border-ink-200 text-ink-500 mb-3">
                            <Icon Name="trophy" Class="w-5 h-5"/>
                        </div>
                        <div class="text-sm font-medium text-ink-900">Outcome not recorded yet</div>
                        <div class="mt-1 text-xs text-ink-500">Click <em>Complete game</em> to add the result and score.</div>
                        <button class="btn btn-primary mt-4" @onclick="StartComplete">
                            <Icon Name="check-circle" Class="w-4 h-4"/> Complete game
                        </button>
                    </div>
                }
            </section>

            @* ============================== NOTE ============================== *@
            @if (!_showCompleteForm && !string.IsNullOrWhiteSpace(_game.Note))
            {
                <section>
                    <div class="flex items-end justify-between mb-3">
                        <h2 class="text-xl font-semibold" style="font-family: var(--font-serif);">Notes</h2>
                    </div>
                    <div class="surface px-5 md:px-6 py-4 text-ink-700 whitespace-pre-wrap">@_game.Note</div>
                </section>
            }

            @* ============================== ACTION BAR (complete flow) ============================== *@
            @if (_showCompleteForm)
            {
                <div class="sticky bottom-3 z-10">
                    <div class="surface px-5 py-3 flex flex-wrap items-center gap-2 shadow-sm">
                        <div class="text-xs text-ink-500 mr-auto">
                            Saving will convert this draft into a <strong class="text-ink-800">completed game</strong>.
                        </div>
                        <button class="btn btn-primary" @onclick="CompleteGame" disabled="@_saving">
                            <Icon Name="check-circle" Class="w-4 h-4"/> Save result
                        </button>
                        <button class="btn btn-ghost" @onclick="CancelComplete">Cancel</button>
                    </div>
                </div>
            }
        </div>

        @* ============================== STICKY SUMMARY (lg+) ============================== *@
        <aside class="hidden lg:block lg:sticky lg:top-6 lg:self-start mt-8 lg:mt-0">
            <div class="surface overflow-hidden">
                @{
                    var headerWin = _game.Result?.Win == true;
                    var headerLoss = _game.Result is not null && _game.Result.Win == false;
                }
                <div class="@(headerWin ? "bg-gradient-to-br from-accent-700 to-accent-900 text-white" : headerLoss ? "bg-gradient-to-br from-red-700 to-red-900 text-white" : "bg-gradient-to-br from-ink-700 to-ink-900 text-white") px-5 py-4">
                    <div class="text-[10px] uppercase tracking-wider opacity-80 font-semibold">
                        @(_game.Result is null ? "Difficulty" : "Score")
                    </div>
                    <div class="text-3xl font-bold leading-none mt-1" style="font-family: var(--font-serif);">
                        @(_game.Result?.Score ?? _game.Difficulty)
                    </div>
                    <div class="text-[11px] opacity-80 mt-1.5">
                        @if (_game.Result is null)
                        {
                            <span>Draft · outcome not recorded</span>
                        }
                        else
                        {
                            <span>Difficulty @_game.Difficulty · @(_game.Result.Win ? "Victory" : "Defeat")</span>
                        }
                    </div>
                </div>

                @* Players quick list *@
                <div class="px-5 py-4">
                    <div class="text-[10px] uppercase tracking-wider text-ink-500 mb-2 font-medium">
                        Players · @_game.Players.Count
                    </div>
                    <ul class="space-y-2">
                        @foreach (var p in _game.Players)
                        {
                            var spirit = GameLookups.SpiritFor(p.SpiritId);
                            var spiritDetail = spirit is null ? null : SpiritDetails.For(spirit.Id);
                            var color = spiritDetail?.ColorHex ?? "#78716c";
                            var board = GameLookups.BoardFor(p.BoardId);
                            var boardDetail = board is null ? null : BoardDetails.For(board.Id);
                            var aspect = GameLookups.AspectFor(p.AspectId);

                            <li class="flex items-start gap-2 text-xs">
                                <span class="inline-block h-7 w-1 rounded-full shrink-0 mt-0.5" style="background-color: @color;"></span>
                                <div class="min-w-0 flex-1">
                                    <div class="text-ink-900 truncate font-medium">
                                        @(spirit?.Name ?? "Unknown spirit")@if (aspect is not null) { <span class="text-ink-500 font-normal"> · @aspect.Name</span> }
                                    </div>
                                    <div class="text-[11px] text-ink-500 truncate">
                                        @if (board is not null)
                                        {
                                            <span>Board @(boardDetail?.Letter ?? board.Name[^1..])</span>
                                            @if (boardDetail is not null)
                                            {
                                                <span> · @boardDetail.ThematicName</span>
                                            }
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>

                @* Date *@
                <div class="px-5 py-4 border-t border-ink-100">
                    <div class="text-[10px] uppercase tracking-wider text-ink-500 mb-1 font-medium">Date played</div>
                    <div class="text-xs text-ink-700">@_game.StartedAt.LocalDateTime.ToString("MMMM d, yyyy")</div>
                </div>

                @if (_game.Result is not null)
                {
                    <div class="px-5 py-4 border-t border-ink-100">
                        <div class="text-[10px] uppercase tracking-wider text-ink-500 mb-1 font-medium">Duration</div>
                        <div class="text-xs text-ink-700">@FormatDuration(_game.Result.Duration)</div>
                    </div>
                }
            </div>
        </aside>
    </div>

    <ConfirmDialog @ref="_confirmDialog" Title="Delete game" Message="Are you sure you want to delete this game? This cannot be undone."/>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Application.Features.Games.GetGameResponse? _game;
    private List<Application.Features.Friendships.FriendResponse> _friends = [];
    private List<Application.Features.Players.ListPlayersResponse> _localPlayers = [];

    private bool _loading = true;
    private bool _saving;
    private bool _showCompleteForm;
    private string? _message;
    private string _alertType = "danger";
    private FormErrors _errors = FormErrors.Empty;

    private bool _resultWin = true;
    private TerrorLevel _resultTerror = TerrorLevel.First;
    private int _resultDurationMinutes = 60;
    private int _resultDahan;
    private int _resultBlight;
    private int _resultCards;
    private int _resultScoreModifier;
    private string? _resultNote;

    private ConfirmDialog _confirmDialog = default!;

    protected override async Task OnInitializedAsync()
    {
        var gameResult = await Mediator.Send(new Application.Features.Games.GetGameQuery(Id));
        if (gameResult.IsSuccess) _game = gameResult.Value;

        if (CurrentUser.UserId is { } uid)
        {
            var friendsResult = await Mediator.Send(new Application.Features.Friendships.ListFriendsQuery(uid));
            if (friendsResult.IsSuccess) _friends = friendsResult.Value;

            var playersResult = await Mediator.Send(new Application.Features.Players.ListPlayersQuery(uid));
            if (playersResult.IsSuccess) _localPlayers = playersResult.Value;
        }

        _loading = false;
    }

    private void StartComplete()
    {
        _showCompleteForm = true;
        _message = null;
        _errors = FormErrors.Empty;
    }

    private void CancelComplete()
    {
        _showCompleteForm = false;
        _errors = FormErrors.Empty;
    }

    private async Task CompleteGame()
    {
        _saving = true;
        var dto = new Application.Features.Games.Dtos.GameResultDto(
            _resultWin, TimeSpan.FromMinutes(_resultDurationMinutes),
            _resultCards, _resultTerror, _resultBlight, _resultDahan, _resultScoreModifier);

        var result = await Mediator.Send(new Application.Features.Games.CompleteGameCommand(Id, dto, _resultNote));
        _saving = false;
        _errors = FormErrors.FromResult(result);

        if (result.IsSuccess)
        {
            _message = "Game completed successfully!";
            _alertType = "success";
            _showCompleteForm = false;
            var reload = await Mediator.Send(new Application.Features.Games.GetGameQuery(Id));
            if (reload.IsSuccess) _game = reload.Value;
        }
        else if (_errors.Any)
        {
            _message = null;
        }
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    private async Task DeleteGame()
    {
        if (!await _confirmDialog.ShowAsync()) return;

        var result = await Mediator.Send(new Application.Features.Games.DeleteGameCommand(Id));
        _errors = FormErrors.FromResult(result);
        if (result.IsSuccess)
            Nav.NavigateTo("/app/games");
        else if (_errors.Any)
            _message = null;
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    private static string FormatDuration(TimeSpan d)
    {
        if (d.TotalHours >= 1)
        {
            return d.Minutes == 0
                ? $"{(int)d.TotalHours} h"
                : $"{(int)d.TotalHours} h {d.Minutes} min";
        }
        return $"{(int)d.TotalMinutes} min";
    }
}
