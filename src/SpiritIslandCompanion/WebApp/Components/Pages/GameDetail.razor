@page "/app/games/{Id:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>Game Detail</PageTitle>

@if (_loading)
{
    <LoadingSpinner/>
}
else if (_game is null)
{
    <div class="alert alert-warn">
        <Icon Name="x" Class="w-5 h-5"/>
        <div>Game not found.</div>
    </div>
}
else
{
    <div class="page-head">
        <div>
            <a href="/app/games" class="text-sm text-ink-500 hover:text-ink-700 inline-flex items-center gap-1 mb-2">
                <Icon Name="arrow-left" Class="w-3.5 h-3.5"/> Games
            </a>
            <h1 class="page-title">Game · @_game.StartedAt.LocalDateTime.ToString("MMMM dd, yyyy")</h1>
            <div class="mt-2"><GameStatusBadge IsCompleted="_game.IsCompleted" Win="_game.Result?.Win"/></div>
        </div>
        <div class="flex flex-wrap gap-2">
            @if (!_game.IsCompleted)
            {
                <button class="btn btn-primary" @onclick="() => _showCompleteForm = !_showCompleteForm">
                    <Icon Name="check-circle" Class="w-4 h-4"/> Complete game
                </button>
            }
            <button class="btn btn-danger-outline" @onclick="DeleteGame">
                <Icon Name="trash" Class="w-4 h-4"/> Delete
            </button>
        </div>
    </div>

    <Alert Message="@_message" Type="@_alertType"/>
    <FormErrorSummary Errors="@_errors"/>

    <div class="grid md:grid-cols-2 gap-5">
        <section class="surface">
            <div class="surface-head"><h2 class="text-base font-semibold">Setup</h2></div>
            <div class="surface-body">
                <dl class="grid grid-cols-3 gap-y-3 text-sm">
                    <dt class="text-ink-500">Island setup</dt>
                    <dd class="col-span-2 text-ink-900">
                        @_game.IslandSetupId
                        @if (_game.ThematicMaps)
                        {
                            <span class="ml-2 inline-flex items-center text-[10px] uppercase tracking-wider text-accent-700 bg-accent-50 px-1.5 py-0.5 rounded">Thematic</span>
                        }
                        @if (_game.ExtraBoard)
                        {
                            <span class="ml-1 inline-flex items-center text-[10px] uppercase tracking-wider text-accent-700 bg-accent-50 px-1.5 py-0.5 rounded">Extra board</span>
                        }
                    </dd>
                    <dt class="text-ink-500">Difficulty</dt>
                    <dd class="col-span-2 text-ink-900">
                        @_game.Difficulty
                        @if (_game.DifficultyModifier != 0)
                        {
                            <span class="text-ink-500 text-xs ml-1">(modifier @(_game.DifficultyModifier > 0 ? "+" : "")@_game.DifficultyModifier)</span>
                        }
                    </dd>
                    <dt class="text-ink-500">Scenario</dt>
                    <dd class="col-span-2 text-ink-900">@(_game.ScenarioId ?? "None")</dd>
                </dl>
            </div>
        </section>

        <section class="surface">
            <div class="surface-head"><h2 class="text-base font-semibold">Players</h2></div>
            <div class="table-wrap">
                <table class="table">
                    <thead><tr><th>Spirit</th><th>Board</th><th>Aspect</th></tr></thead>
                    <tbody>
                    @foreach (var p in _game.Players)
                    {
                        <tr>
                            <td class="font-medium text-ink-900">@p.SpiritId</td>
                            <td class="text-ink-600">@p.BoardId</td>
                            <td class="text-ink-600">@(p.AspectId ?? "—")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        @if (_game.Adversaries.Count > 0)
        {
            <section class="surface">
                <div class="surface-head"><h2 class="text-base font-semibold">Adversaries</h2></div>
                <div class="table-wrap">
                    <table class="table">
                        <thead><tr><th>Adversary</th><th class="text-right">Level</th></tr></thead>
                        <tbody>
                        @foreach (var a in _game.Adversaries)
                        {
                            <tr>
                                <td class="font-medium text-ink-900">@a.AdversaryId</td>
                                <td class="text-right">@a.Level</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (_game.Result is not null)
        {
            <section class="surface">
                <div class="surface-head">
                    <h2 class="text-base font-semibold">Result</h2>
                    <span class="text-xl font-semibold" style="font-family: var(--font-serif);">@_game.Result.Score</span>
                </div>
                <div class="surface-body">
                    <dl class="grid grid-cols-3 gap-y-3 text-sm">
                        <dt class="text-ink-500">Outcome</dt>
                        <dd class="col-span-2 text-ink-900">@(_game.Result.Win ? "Victory" : "Defeat")</dd>
                        <dt class="text-ink-500">Terror level</dt>
                        <dd class="col-span-2 text-ink-900">@_game.Result.TerrorLevel</dd>
                        <dt class="text-ink-500">Duration</dt>
                        <dd class="col-span-2 text-ink-900">@_game.Result.Duration.ToString(@"h\:mm")</dd>
                        <dt class="text-ink-500">Dahan</dt>
                        <dd class="col-span-2 text-ink-900">@_game.Result.Dahan</dd>
                        <dt class="text-ink-500">Blight</dt>
                        <dd class="col-span-2 text-ink-900">@_game.Result.Blight</dd>
                        <dt class="text-ink-500">@(_game.Result.Win ? "Cards remaining" : "Cards used")</dt>
                        <dd class="col-span-2 text-ink-900">@_game.Result.Cards</dd>
                    </dl>
                </div>
            </section>
        }

        @if (_game.Note is not null)
        {
            <section class="surface md:col-span-2">
                <div class="surface-head"><h2 class="text-base font-semibold">Notes</h2></div>
                <div class="surface-body text-ink-700 whitespace-pre-wrap">@_game.Note</div>
            </section>
        }
    </div>

    @if (_showCompleteForm)
    {
        <section class="surface mt-6">
            <div class="surface-head"><h2 class="text-base font-semibold">Complete game</h2></div>
            <div class="surface-body">
                <div class="grid md:grid-cols-4 gap-4">
                    <div>
                        <label class="label">Outcome</label>
                        <select class="select" @bind="_resultWin">
                            <option value="true">Victory</option>
                            <option value="false">Defeat</option>
                        </select>
                    </div>
                    <div>
                        <label class="label">Terror level</label>
                        <select class="select" @bind="_resultTerror">
                            @foreach (var t in Enum.GetValues<TerrorLevel>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                        <FieldError For="Result.TerrorLevel" Errors="@_errors"/>
                    </div>
                    <div>
                        <label class="label">Duration (min)</label>
                        <input type="number" class="input" @bind="_resultDurationMinutes" min="0"/>
                        <FieldError For="Result.Duration" Errors="@_errors"/>
                    </div>
                    <div>
                        <label class="label">Dahan remaining</label>
                        <input type="number" class="input" @bind="_resultDahan" min="0"/>
                        <FieldError For="Result.Dahan" Errors="@_errors"/>
                    </div>
                    <div>
                        <label class="label">Blight on island</label>
                        <input type="number" class="input" @bind="_resultBlight" min="0"/>
                        <FieldError For="Result.Blight" Errors="@_errors"/>
                    </div>
                    <div>
                        <label class="label">@(_resultWin ? "Cards remaining in deck" : "Enemy cards used")</label>
                        <input type="number" class="input" @bind="_resultCards" min="0"/>
                        <FieldError For="Result.Cards" Errors="@_errors"/>
                    </div>
                    <div>
                        <label class="label">Score modifier</label>
                        <input type="number" class="input" @bind="_resultScoreModifier"/>
                        <FieldError For="Result.ScoreModifier" Errors="@_errors"/>
                    </div>
                    <div class="md:col-span-4">
                        <label class="label">Note</label>
                        <textarea class="textarea" rows="2" @bind="_resultNote"></textarea>
                        <FieldError For="Note" Errors="@_errors"/>
                    </div>
                </div>
            </div>
            <div class="surface-foot">
                <button class="btn btn-primary" @onclick="CompleteGame">
                    <Icon Name="check" Class="w-4 h-4"/> Save result
                </button>
            </div>
        </section>
    }

    <ConfirmDialog @ref="_confirmDialog" Title="Delete game" Message="Are you sure you want to delete this game? This cannot be undone."/>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Application.Features.Games.GetGameResponse? _game;
    private bool _loading = true;
    private bool _showCompleteForm;
    private string? _message;
    private string _alertType = "danger";
    private FormErrors _errors = FormErrors.Empty;

    private bool _resultWin = true;
    private TerrorLevel _resultTerror = TerrorLevel.First;
    private int _resultDurationMinutes = 60;
    private int _resultDahan;
    private int _resultBlight;
    private int _resultCards;
    private int _resultScoreModifier;
    private string? _resultNote;

    private ConfirmDialog _confirmDialog = default!;

    protected override async Task OnInitializedAsync()
    {
        var result = await Mediator.Send(new Application.Features.Games.GetGameQuery(Id));
        if (result.IsSuccess) _game = result.Value;
        _loading = false;
    }

    private async Task CompleteGame()
    {
        var dto = new Application.Features.Games.Dtos.GameResultDto(
            _resultWin, TimeSpan.FromMinutes(_resultDurationMinutes),
            _resultCards, _resultTerror, _resultBlight, _resultDahan, _resultScoreModifier);

        var result = await Mediator.Send(new Application.Features.Games.CompleteGameCommand(Id, dto, _resultNote));
        _errors = FormErrors.FromResult(result);
        if (result.IsSuccess)
        {
            _message = "Game completed successfully!";
            _alertType = "success";
            _showCompleteForm = false;
            var reload = await Mediator.Send(new Application.Features.Games.GetGameQuery(Id));
            if (reload.IsSuccess) _game = reload.Value;
        }
        else if (_errors.Any)
        {
            _message = null;
        }
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    private async Task DeleteGame()
    {
        if (!await _confirmDialog.ShowAsync()) return;

        var result = await Mediator.Send(new Application.Features.Games.DeleteGameCommand(Id));
        _errors = FormErrors.FromResult(result);
        if (result.IsSuccess)
            Nav.NavigateTo("/app/games");
        else if (_errors.Any)
            _message = null;
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }
}
