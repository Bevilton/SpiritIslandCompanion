@page "/games/{Id:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>Game Detail</PageTitle>

@if (_loading)
{
    <LoadingSpinner/>
}
else if (_game is null)
{
    <div class="alert alert-warning">Game not found.</div>
}
else
{
    <div class="page-header d-flex align-items-center justify-content-between">
        <div>
            <h1>Game - @_game.StartedAt.LocalDateTime.ToString("MMM dd, yyyy")</h1>
            <GameStatusBadge IsCompleted="_game.IsCompleted" Win="_game.Result?.Win"/>
        </div>
        <div class="d-flex gap-2">
            @if (!_game.IsCompleted)
            {
                <button class="btn btn-success" @onclick="() => _showCompleteForm = !_showCompleteForm">
                    <i class="bi bi-check-circle me-1"></i> Complete Game
                </button>
            }
            <button class="btn btn-outline-danger" @onclick="DeleteGame">
                <i class="bi bi-trash me-1"></i> Delete
            </button>
        </div>
    </div>

    <Alert Message="@_message" Type="@_alertType"/>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header"><h6 class="mb-0">Setup</h6></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Island Setup</dt>
                        <dd class="col-sm-7">@_game.IslandSetupId</dd>
                        <dt class="col-sm-5">Difficulty</dt>
                        <dd class="col-sm-7">@_game.Difficulty</dd>
                        <dt class="col-sm-5">Scenario</dt>
                        <dd class="col-sm-7">@(_game.ScenarioId ?? "None")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header"><h6 class="mb-0">Players</h6></div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Spirit</th><th>Board</th><th>Aspect</th></tr></thead>
                        <tbody>
                        @foreach (var p in _game.Players)
                        {
                            <tr>
                                <td>@p.SpiritId</td>
                                <td>@p.BoardId</td>
                                <td>@(p.AspectId ?? "-")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (_game.Adversaries.Count > 0)
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><h6 class="mb-0">Adversaries</h6></div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Adversary</th><th>Level</th></tr></thead>
                            <tbody>
                            @foreach (var a in _game.Adversaries)
                            {
                                <tr><td>@a.AdversaryId</td><td>@a.Level</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (_game.Result is not null)
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><h6 class="mb-0">Result</h6></div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Outcome</dt>
                            <dd class="col-sm-7">@(_game.Result.Win ? "Victory" : "Defeat")</dd>
                            <dt class="col-sm-5">Score</dt>
                            <dd class="col-sm-7 fw-bold">@_game.Result.Score</dd>
                            <dt class="col-sm-5">Terror Level</dt>
                            <dd class="col-sm-7">@_game.Result.TerrorLevel</dd>
                            <dt class="col-sm-5">Duration</dt>
                            <dd class="col-sm-7">@_game.Result.Duration.ToString(@"h\:mm")</dd>
                            <dt class="col-sm-5">Dahan</dt>
                            <dd class="col-sm-7">@_game.Result.Dahan</dd>
                            <dt class="col-sm-5">Blight</dt>
                            <dd class="col-sm-7">@_game.Result.Blight</dd>
                            <dt class="col-sm-5">Cards in Deck</dt>
                            <dd class="col-sm-7">@_game.Result.Cards</dd>
                        </dl>
                    </div>
                </div>
            </div>
        }

        @if (_game.Note is not null)
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-header"><h6 class="mb-0">Notes</h6></div>
                    <div class="card-body">@_game.Note</div>
                </div>
            </div>
        }
    </div>

    @if (_showCompleteForm)
    {
        <div class="card mt-4">
            <div class="card-header"><h6 class="mb-0">Complete Game</h6></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Outcome</label>
                        <select class="form-select" @bind="_resultWin">
                            <option value="true">Victory</option>
                            <option value="false">Defeat</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Terror Level</label>
                        <select class="form-select" @bind="_resultTerror">
                            @foreach (var t in Enum.GetValues<TerrorLevel>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Duration (minutes)</label>
                        <input type="number" class="form-control" @bind="_resultDurationMinutes" min="0"/>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Dahan Remaining</label>
                        <input type="number" class="form-control" @bind="_resultDahan" min="0"/>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Blight on Island</label>
                        <input type="number" class="form-control" @bind="_resultBlight" min="0"/>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Cards in Invader Deck</label>
                        <input type="number" class="form-control" @bind="_resultCards" min="0"/>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Score Modifier</label>
                        <input type="number" class="form-control" @bind="_resultScoreModifier"/>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Note</label>
                        <textarea class="form-control" rows="2" @bind="_resultNote"></textarea>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-success" @onclick="CompleteGame">
                            <i class="bi bi-check-lg me-1"></i> Save Result
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <ConfirmDialog @ref="_confirmDialog" Title="Delete Game" Message="Are you sure you want to delete this game? This cannot be undone."/>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Application.Features.Games.GetGameResponse? _game;
    private bool _loading = true;
    private bool _showCompleteForm;
    private string? _message;
    private string _alertType = "danger";

    // Complete form fields
    private bool _resultWin = true;
    private TerrorLevel _resultTerror = TerrorLevel.First;
    private int _resultDurationMinutes = 60;
    private int _resultDahan;
    private int _resultBlight;
    private int _resultCards;
    private int _resultScoreModifier;
    private string? _resultNote;

    private ConfirmDialog _confirmDialog = default!;

    protected override async Task OnInitializedAsync()
    {
        var result = await Mediator.Send(new Application.Features.Games.GetGameQuery(Id));
        if (result.IsSuccess) _game = result.Value;
        _loading = false;
    }

    private async Task CompleteGame()
    {
        var dto = new Application.Features.Games.Dtos.GameResultDto(
            _resultWin, TimeSpan.FromMinutes(_resultDurationMinutes),
            _resultCards, _resultTerror, _resultBlight, _resultDahan, _resultScoreModifier);

        var result = await Mediator.Send(new Application.Features.Games.CompleteGameCommand(Id, dto, _resultNote));
        if (result.IsSuccess)
        {
            _message = "Game completed successfully!";
            _alertType = "success";
            _showCompleteForm = false;
            // Reload
            var reload = await Mediator.Send(new Application.Features.Games.GetGameQuery(Id));
            if (reload.IsSuccess) _game = reload.Value;
        }
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    private async Task DeleteGame()
    {
        if (!await _confirmDialog.ShowAsync()) return;

        var result = await Mediator.Send(new Application.Features.Games.DeleteGameCommand(Id));
        if (result.IsSuccess)
            Nav.NavigateTo("/games");
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }
}
