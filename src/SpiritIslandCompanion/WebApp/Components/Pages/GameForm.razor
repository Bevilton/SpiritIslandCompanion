@page "/app/games/new"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>New Game</PageTitle>

<div class="page-head">
    <div>
        <span class="eyebrow">Record a match</span>
        <h1 class="page-title mt-2">New game</h1>
    </div>
    <a href="/app/games" class="btn btn-ghost">
        <Icon Name="arrow-left" Class="w-4 h-4"/> Back to games
    </a>
</div>

<Alert Message="@_message" Type="@_alertType"/>

@if (_loading)
{
    <LoadingSpinner/>
}
else
{
    @* === SETUP === *@
    <section class="surface mb-5">
        <div class="surface-head"><h2 class="text-base font-semibold">Game setup</h2></div>
        <div class="surface-body space-y-4">
            <div>
                <label class="label">Island setup</label>
                <IslandSetupPicker @bind-Value="_islandSetupId"/>
            </div>
            <div class="grid md:grid-cols-3 gap-4">
                <div>
                    <label class="label">Difficulty</label>
                    <input type="number" class="input" @bind="_difficulty" min="0" max="20"/>
                </div>
                <div>
                    <label class="label">Scenario</label>
                    <select class="select" @bind="_scenarioId">
                        <option value="">None</option>
                        @foreach (var s in GameData.Scenarios)
                        {
                            <option value="@s.Id.Value">@s.Name (Diff +@s.Difficulty)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="label">Date played</label>
                    <input type="date" class="input" @bind="_datePlayed"/>
                </div>
            </div>
        </div>
    </section>

    @* === PLAYERS === *@
    <section class="surface mb-5">
        <div class="surface-head">
            <h2 class="text-base font-semibold">Players</h2>
            <button class="btn btn-sm btn-secondary" @onclick="AddPlayer">
                <Icon Name="plus" Class="w-3.5 h-3.5"/> Add player
            </button>
        </div>
        <div class="surface-body space-y-4">
            @for (var i = 0; i < _players.Count; i++)
            {
                var idx = i;
                <div class="grid md:grid-cols-12 gap-3 items-end pb-4 border-b border-ink-100 last:border-0 last:pb-0">
                    <div class="md:col-span-3">
                        <label class="label">Spirit</label>
                        <select class="select" value="@_players[idx].SpiritId"
                                @onchange="e => OnSpiritChanged(idx, e.Value?.ToString())">
                            <option value="">Select…</option>
                            @foreach (var s in GameData.Spirits)
                            {
                                <option value="@s.Id.Value">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="label">Aspect</label>
                        <select class="select" @bind="_players[idx].AspectId">
                            <option value="">None</option>
                            @foreach (var a in GetAspectsForSpirit(_players[idx].SpiritId))
                            {
                                <option value="@a.Id.Value">@a.Name</option>
                            }
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="label">Board</label>
                        <select class="select" @bind="_players[idx].BoardId">
                            <option value="">Select…</option>
                            @foreach (var b in GameData.Boards)
                            {
                                <option value="@b.Id.Value">@b.Name</option>
                            }
                        </select>
                    </div>
                    <div class="md:col-span-3">
                        <label class="label">Assigned to</label>
                        <select class="select" @bind="_players[idx].AssignedTo">
                            <option value="me">Me</option>
                            @foreach (var f in _friends)
                            {
                                <option value="friend:@f.FriendUserId">@f.Nickname</option>
                            }
                            @foreach (var p in _localPlayers)
                            {
                                <option value="player:@p.Id">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="md:col-span-2 flex justify-end">
                        @if (_players.Count > 1)
                        {
                            <button class="btn btn-sm btn-danger-outline" @onclick="() => RemovePlayer(idx)">
                                <Icon Name="trash" Class="w-3.5 h-3.5"/>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    @* === ADVERSARIES === *@
    <section class="surface mb-5">
        <div class="surface-head">
            <h2 class="text-base font-semibold">Adversaries</h2>
            <button class="btn btn-sm btn-secondary" @onclick="AddAdversary">
                <Icon Name="plus" Class="w-3.5 h-3.5"/> Add adversary
            </button>
        </div>
        <div class="surface-body">
            @if (_adversaries.Count == 0)
            {
                <p class="text-sm text-ink-500 m-0">No adversary — tutorial / freeplay game.</p>
            }
            <div class="space-y-3">
                @for (var i = 0; i < _adversaries.Count; i++)
                {
                    var idx = i;
                    <div class="grid md:grid-cols-12 gap-3 items-end">
                        <div class="md:col-span-7">
                            <label class="label">Adversary</label>
                            <select class="select" @bind="_adversaries[idx].AdversaryId">
                                <option value="">Select…</option>
                                @foreach (var a in GameData.Adversaries)
                                {
                                    <option value="@a.Id.Value">@a.Name</option>
                                }
                            </select>
                        </div>
                        <div class="md:col-span-3">
                            <label class="label">Level</label>
                            <input type="number" class="input" @bind="_adversaries[idx].Level" min="0" max="6"/>
                        </div>
                        <div class="md:col-span-2 flex justify-end">
                            <button class="btn btn-sm btn-danger-outline" @onclick="() => _adversaries.RemoveAt(idx)">
                                <Icon Name="trash" Class="w-3.5 h-3.5"/>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    @* === RESULT (optional) === *@
    <section class="surface mb-5">
        <div class="surface-head">
            <h2 class="text-base font-semibold">Result</h2>
            <label class="inline-flex items-center gap-2 text-sm text-ink-700">
                <input type="checkbox" class="checkbox" @bind="_includeResult"/>
                Include result
            </label>
        </div>
        @if (_includeResult)
        {
            <div class="surface-body">
                <div class="grid md:grid-cols-4 gap-4">
                    <div>
                        <label class="label">Outcome</label>
                        <select class="select" @bind="_resultWin">
                            <option value="true">Victory</option>
                            <option value="false">Defeat</option>
                        </select>
                    </div>
                    <div>
                        <label class="label">Terror level</label>
                        <select class="select" @bind="_resultTerror">
                            @foreach (var t in Enum.GetValues<TerrorLevel>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="label">Duration (min)</label>
                        <input type="number" class="input" @bind="_resultDuration" min="0"/>
                    </div>
                    <div>
                        <label class="label">Dahan remaining</label>
                        <input type="number" class="input" @bind="_resultDahan" min="0"/>
                    </div>
                    <div>
                        <label class="label">Blight on island</label>
                        <input type="number" class="input" @bind="_resultBlight" min="0"/>
                    </div>
                    <div>
                        <label class="label">Cards in invader deck</label>
                        <input type="number" class="input" @bind="_resultCards" min="0"/>
                    </div>
                    <div>
                        <label class="label">Score modifier</label>
                        <input type="number" class="input" @bind="_resultScoreMod"/>
                    </div>
                </div>
            </div>
        }
    </section>

    @* === NOTE === *@
    <section class="surface mb-6">
        <div class="surface-head"><h2 class="text-base font-semibold">Note</h2></div>
        <div class="surface-body">
            <textarea class="textarea" rows="3" @bind="_note" placeholder="Optional game notes…"></textarea>
        </div>
    </section>

    <div class="flex flex-wrap items-center gap-2">
        @if (_includeResult)
        {
            <button class="btn btn-primary" @onclick="SaveCompleted" disabled="@_saving">
                <Icon Name="check-circle" Class="w-4 h-4"/> Save completed game
            </button>
        }
        else
        {
            <button class="btn btn-primary" @onclick="SaveDraft" disabled="@_saving">
                <Icon Name="save" Class="w-4 h-4"/> Save as draft
            </button>
        }
        <a href="/app/games" class="btn btn-ghost">Cancel</a>
    </div>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private string? _message;
    private string _alertType = "danger";

    private string _islandSetupId = "";
    private int _difficulty;
    private string? _scenarioId;
    private DateTime _datePlayed = DateTime.Today;

    private List<PlayerFormItem> _players = [new()];
    private List<Application.Features.Friendships.FriendResponse> _friends = [];
    private List<Application.Features.Players.ListPlayersResponse> _localPlayers = [];

    private List<AdversaryFormItem> _adversaries = [];

    private bool _includeResult;
    private bool _resultWin = true;
    private TerrorLevel _resultTerror = TerrorLevel.First;
    private int _resultDuration = 60;
    private int _resultDahan;
    private int _resultBlight;
    private int _resultCards;
    private int _resultScoreMod;
    private string? _note;

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser.UserId is not { } userId) return;

        var friendsResult = await Mediator.Send(new Application.Features.Friendships.ListFriendsQuery(userId));
        var playersResult = await Mediator.Send(new Application.Features.Players.ListPlayersQuery(userId));

        if (friendsResult.IsSuccess) _friends = friendsResult.Value;
        if (playersResult.IsSuccess) _localPlayers = playersResult.Value;

        _loading = false;
    }

    private void AddPlayer() => _players.Add(new PlayerFormItem());
    private void RemovePlayer(int idx) => _players.RemoveAt(idx);
    private void AddAdversary() => _adversaries.Add(new AdversaryFormItem());

    private void OnSpiritChanged(int idx, string? spiritId)
    {
        _players[idx].SpiritId = spiritId ?? "";
        _players[idx].AspectId = "";
    }

    private IReadOnlyList<Aspect> GetAspectsForSpirit(string spiritId)
        => string.IsNullOrEmpty(spiritId) ? [] : GameData.GetAspectsForSpirit(new SpiritId(spiritId));

    private List<Application.Features.Games.Dtos.GamePlayerDto> BuildPlayerDtos()
    {
        return _players.Select(p =>
        {
            Guid? userId = null;
            Guid? playerId = null;

            if (p.AssignedTo == "me")
                userId = CurrentUser.UserId;
            else if (p.AssignedTo.StartsWith("friend:"))
                userId = Guid.Parse(p.AssignedTo["friend:".Length..]);
            else if (p.AssignedTo.StartsWith("player:"))
                playerId = Guid.Parse(p.AssignedTo["player:".Length..]);

            return new Application.Features.Games.Dtos.GamePlayerDto(
                p.SpiritId, string.IsNullOrEmpty(p.AspectId) ? null : p.AspectId,
                p.BoardId, userId, playerId);
        }).ToList();
    }

    private List<Application.Features.Games.Dtos.GameAdversaryDto> BuildAdversaryDtos()
        => _adversaries.Select(a => new Application.Features.Games.Dtos.GameAdversaryDto(a.AdversaryId, a.Level)).ToList();

    private async Task SaveDraft()
    {
        _saving = true;
        var cmd = new Application.Features.Games.DraftGameCommand(
            CurrentUser.UserId!.Value,
            new DateTimeOffset(_datePlayed, TimeSpan.Zero),
            _islandSetupId, _difficulty,
            BuildPlayerDtos(), BuildAdversaryDtos(),
            string.IsNullOrEmpty(_scenarioId) ? null : _scenarioId,
            string.IsNullOrEmpty(_note) ? null : _note);

        var result = await Mediator.Send(cmd);
        _saving = false;

        if (result.IsSuccess)
            Nav.NavigateTo("/app/games");
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    private async Task SaveCompleted()
    {
        _saving = true;
        var resultDto = new Application.Features.Games.Dtos.GameResultDto(
            _resultWin, TimeSpan.FromMinutes(_resultDuration),
            _resultCards, _resultTerror, _resultBlight, _resultDahan, _resultScoreMod);

        var cmd = new Application.Features.Games.CreateGameCommand(
            CurrentUser.UserId!.Value,
            new DateTimeOffset(_datePlayed, TimeSpan.Zero),
            _islandSetupId, _difficulty,
            BuildPlayerDtos(), BuildAdversaryDtos(),
            string.IsNullOrEmpty(_scenarioId) ? null : _scenarioId,
            resultDto,
            string.IsNullOrEmpty(_note) ? null : _note);

        var result = await Mediator.Send(cmd);
        _saving = false;

        if (result.IsSuccess)
            Nav.NavigateTo("/app/games");
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    private class PlayerFormItem
    {
        public string SpiritId { get; set; } = "";
        public string? AspectId { get; set; }
        public string BoardId { get; set; } = "";
        public string AssignedTo { get; set; } = "me";
    }

    private class AdversaryFormItem
    {
        public string AdversaryId { get; set; } = "";
        public int Level { get; set; }
    }
}
