@page "/app/games/new"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>New Game</PageTitle>

<div class="page-head">
    <div>
        <span class="eyebrow">Record a match</span>
        <h1 class="page-title mt-2">New game</h1>
    </div>
    <a href="/app/games" class="btn btn-ghost">
        <Icon Name="arrow-left" Class="w-4 h-4"/> Back to games
    </a>
</div>

<Alert Message="@_message" Type="@_alertType"/>
<FormErrorSummary Errors="@_errors"/>

@if (_loading)
{
    <LoadingSpinner/>
}
else
{
    @* === COMPACT SUMMARY (mobile + tablet only) — replaced on lg+ by the right sticky panel === *@
    <div class="lg:hidden surface mb-6 px-5 py-4 grid @(_includeResult ? "grid-cols-3" : "grid-cols-2") gap-4 items-start">
        <div>
            <div class="text-[10px] uppercase tracking-wider text-ink-500">Players</div>
            <div class="mt-0.5 text-lg font-semibold text-ink-900">@_players.Count @(_players.Count == 1 ? "player" : "players")</div>
        </div>
        <div class="@(_includeResult ? "text-center" : "text-right")">
            <div class="text-[10px] uppercase tracking-wider text-ink-500">Difficulty</div>
            <div class="mt-0.5 text-2xl font-semibold text-accent-800 leading-none" style="font-family: var(--font-serif);">
                @ComputedDifficulty
            </div>
        </div>
        @if (_includeResult)
        {
            <div class="text-right">
                <div class="text-[10px] uppercase tracking-wider text-ink-500">Score</div>
                <div class="mt-0.5 text-2xl font-semibold @(_resultWin ? "text-accent-800" : "text-red-700") leading-none tabular-nums" style="font-family: var(--font-serif);">
                    @ComputedScore
                </div>
            </div>
        }
    </div>

    @* === Two-column grid on lg+: form on the left, sticky summary on the right.
       The aside grid item stretches (default) so the inner sticky panel stays in view
       throughout the entire page scroll. === *@
    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-6">
    <div class="lg:min-w-0">

    @* ============================== PLAYERS ============================== *@
    <section class="mb-8">
        <div class="flex items-end justify-between mb-3">
            <div>
                <span class="eyebrow">Step 1</span>
                <h2 class="text-xl font-semibold mt-1" style="font-family: var(--font-serif);">Players</h2>
                <p class="text-sm text-ink-500">Pick a spirit, board, and who's playing it. Add as many as you need.</p>
            </div>
        </div>

        <FieldError For="Players" Errors="@_errors"/>

        <div class="grid gap-3">
            @for (var i = 0; i < _players.Count; i++)
            {
                var idx = i;
                var p = _players[idx];
                var spirit = SpiritFor(p.SpiritId);
                var spiritDetail = spirit is null ? null : SpiritDetails.For(spirit.Id);
                var color = spiritDetail?.ColorHex ?? "#78716c";
                var aspects = GetAspectsForSpirit(p.SpiritId);
                var board = BoardFor(p.BoardId);
                var boardDetail = board is null ? null : BoardDetails.For(board.Id);
                var hasSpirit = spirit is not null;

                <article class="player-card relative border border-ink-200 rounded-2xl transition-all"
                         style="@(hasSpirit
                                  ? $"border-top: 4px solid {color}; background: linear-gradient(to bottom, {color}14 0%, white 96px);"
                                  : "border-top: 4px dashed var(--color-ink-300); background: white;")">
                    <div class="p-4 md:p-5">
                        @* Header row: P# badge + remove *@
                        <div class="flex items-center justify-between mb-3">
                            <span class="inline-flex items-center gap-2 text-xs font-medium text-ink-500">
                                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full text-[11px] font-semibold"
                                      style="@(hasSpirit ? $"background-color: {color}; color: white;" : "background-color: var(--color-ink-100); color: var(--color-ink-600);")">
                                    @(idx + 1)
                                </span>
                                <span class="uppercase tracking-wide">Player @(idx + 1)</span>
                            </span>
                            @if (_players.Count > 1)
                            {
                                <button type="button"
                                        class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-ink-400 hover:bg-red-50 hover:text-red-600 transition-colors"
                                        @onclick="() => RemovePlayer(idx)"
                                        aria-label="Remove player">
                                    <Icon Name="trash" Class="w-4 h-4"/>
                                </button>
                            }
                        </div>

                        @* Main row: spirit | board | assignee *@
                        <div class="grid md:grid-cols-12 gap-3">
                            @* Spirit picker (taking more room) *@
                            <div class="md:col-span-6">
                                <label class="label">Spirit</label>
                                <button type="button"
                                        @onclick="() => OpenSpiritPicker(idx)"
                                        class="w-full flex items-center gap-3 px-3 py-2 rounded-lg border bg-white hover:bg-ink-50 transition-colors text-left
                                               focus:outline-none focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30
                                               @(hasSpirit ? "border-ink-200" : "border-dashed border-ink-300")">
                                    @if (spirit is not null)
                                    {
                                        <span class="inline-block h-9 w-1.5 rounded-full shrink-0" style="background-color: @color;"></span>
                                        <div class="min-w-0 flex-1">
                                            <div class="text-sm font-semibold text-ink-900 truncate">@spirit.Name</div>
                                            @if (spiritDetail is not null)
                                            {
                                                <div class="text-[11px] text-ink-500 truncate">@spiritDetail.PlayStyle</div>
                                            }
                                        </div>
                                        @if (spiritDetail is not null)
                                        {
                                            <ElementBadges Elements="spiritDetail.Elements" Size="sm"/>
                                        }
                                    }
                                    else
                                    {
                                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-ink-100 text-ink-500 shrink-0">
                                            <Icon Name="sparkles" Class="w-4 h-4"/>
                                        </span>
                                        <span class="text-sm text-ink-500 truncate min-w-0 flex-1">Choose a spirit…</span>
                                    }
                                </button>
                                <FieldError For="@($"Players[{idx}].SpiritId")" Errors="@_errors"/>
                            </div>

                            @* Board picker *@
                            <div class="md:col-span-3">
                                <label class="label">Board</label>
                                <button type="button"
                                        @onclick="() => OpenBoardPicker(idx)"
                                        class="w-full flex items-center gap-2 px-3 py-2 rounded-lg border bg-white hover:bg-ink-50 transition-colors text-left
                                               focus:outline-none focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30
                                               @(board is not null ? "border-ink-200" : "border-dashed border-ink-300")">
                                    @if (board is not null)
                                    {
                                        var bColor = boardDetail?.ColorHex ?? "#78716c";
                                        var letter = boardDetail?.Letter ?? board.Name[^1..];
                                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-white text-base font-semibold shrink-0"
                                              style="background-color: @bColor; font-family: var(--font-serif);">
                                            @letter
                                        </span>
                                        <div class="min-w-0 flex-1">
                                            <div class="text-sm font-semibold text-ink-900 truncate">@board.Name</div>
                                            @if (boardDetail is not null)
                                            {
                                                <div class="text-[11px] text-ink-500 truncate">@boardDetail.ThematicName</div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-ink-100 text-ink-500 shrink-0">
                                            <Icon Name="map" Class="w-4 h-4"/>
                                        </span>
                                        <span class="text-sm text-ink-500 truncate min-w-0 flex-1">Pick…</span>
                                    }
                                </button>
                                <FieldError For="@($"Players[{idx}].BoardId")" Errors="@_errors"/>
                            </div>

                            @* Assignee *@
                            <div class="md:col-span-3">
                                <label class="label">Assigned to</label>
                                <PlayerAssigneePicker
                                    Value="@p.AssignedTo"
                                    ValueChanged="v => OnAssigneeChanged(idx, v)"
                                    Friends="_friends"
                                    LocalPlayers="_localPlayers"/>
                                <FieldError For="@($"Players[{idx}].AssignedTo")" Errors="@_errors"/>
                            </div>
                        </div>

                        @* Aspects row — only when spirit has aspects *@
                        @if (hasSpirit && aspects.Count > 0)
                        {
                            <div class="mt-3 pt-3 border-t border-ink-100 flex items-start gap-2 flex-wrap">
                                <span class="text-[10px] uppercase tracking-wide text-ink-500 mt-1.5 mr-1">Aspect</span>
                                <FilterPill Active="@(string.IsNullOrEmpty(p.AspectId))"
                                            OnToggle="() => SelectAspect(idx, null)">
                                    None
                                </FilterPill>
                                @foreach (var a in aspects)
                                {
                                    var aId = a.Id.Value;
                                    <FilterPill Active="@(p.AspectId == aId)"
                                                OnToggle="() => SelectAspect(idx, aId)">
                                        @a.Name
                                    </FilterPill>
                                }
                            </div>
                        }
                    </div>
                </article>
            }

            @* Add player tile *@
            <button type="button" @onclick="AddPlayer"
                    class="group flex items-center justify-center gap-2 rounded-2xl border-2 border-dashed border-ink-300 bg-ink-50/30 hover:bg-accent-50/40 hover:border-accent-300 transition-colors py-5 text-sm font-medium text-ink-500 hover:text-accent-700">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white border border-ink-200 group-hover:border-accent-300 group-hover:bg-accent-50 transition-colors">
                    <Icon Name="plus" Class="w-4 h-4"/>
                </span>
                Add another player
            </button>
        </div>
    </section>

    @* ============================== SETUP ============================== *@
    <section class="mb-8">
        <div class="flex items-end justify-between mb-3">
            <div>
                <span class="eyebrow">Step 2</span>
                <h2 class="text-xl font-semibold mt-1" style="font-family: var(--font-serif);">Setup</h2>
                <p class="text-sm text-ink-500">Island layout, scenario, and any adversaries you faced.</p>
            </div>
        </div>

        <div class="surface p-5 md:p-6 space-y-5">
            @* ====== Map variant toggles ====== *@
            <div class="grid sm:grid-cols-2 gap-3">
                <div role="button" tabindex="0" aria-pressed="@_extraBoard"
                     @onclick="ToggleExtraBoard"
                     @onkeydown="OnExtraBoardKey"
                     class="flex items-center justify-between gap-3 rounded-xl border @(_extraBoard ? "border-accent-300 bg-accent-50/50" : "border-ink-200 bg-white") px-4 py-3 select-none @(ExtraBoardAllowed ? "cursor-pointer hover:border-ink-300" : "opacity-50 cursor-not-allowed")">
                    <div class="min-w-0 flex items-start gap-1.5">
                        <div>
                            <div class="text-sm font-semibold text-ink-900">Extra board</div>
                            <div class="text-[11px] text-ink-500">@(ExtraBoardAllowed ? $"Plays on {_players.Count + 1} boards · +{GameRestrictions.ExtraBoardDifficultyBonus} difficulty" : "Disabled for 6 players")</div>
                        </div>
                        <span @onclick:stopPropagation="true" @onkeydown:stopPropagation="true" class="mt-0.5">
                            <InfoHint Position="right">
                                Adds one extra board to the island (so @_players.Count player@(_players.Count == 1 ? "" : "s") play on @(_players.Count + 1) boards). Only allowed for 1–5 players. Adds <span class="text-ink-900">+@GameRestrictions.ExtraBoardDifficultyBonus</span> difficulty.
                            </InfoHint>
                        </span>
                    </div>
                    <span class="relative inline-flex h-6 w-11 items-center shrink-0 rounded-full transition-colors @(_extraBoard ? "bg-accent-500" : "bg-ink-200")">
                        <span class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform @(_extraBoard ? "translate-x-5" : "")"></span>
                    </span>
                </div>

                <div role="button" tabindex="0" aria-pressed="@_thematicMaps"
                     @onclick="() => _thematicMaps = !_thematicMaps"
                     @onkeydown="OnThematicMapsKey"
                     class="flex items-center justify-between gap-3 rounded-xl border @(_thematicMaps ? "border-accent-300 bg-accent-50/50" : "border-ink-200 bg-white") px-4 py-3 select-none cursor-pointer hover:border-ink-300">
                    <div class="min-w-0 flex items-start gap-1.5">
                        <div>
                            <div class="text-sm font-semibold text-ink-900">Thematic maps</div>
                            <div class="text-[11px] text-ink-500">+@GameRestrictions.ThematicMapsDifficultyBonus difficulty · thematic-only layouts</div>
                        </div>
                        <span @onclick:stopPropagation="true" @onkeydown:stopPropagation="true" class="mt-0.5">
                            <InfoHint Position="right">
                                Restricts the layout list to thematic island shapes. Adds <span class="text-ink-900">+@GameRestrictions.ThematicMapsDifficultyBonus</span> difficulty. No thematic map exists for 5 boards.
                            </InfoHint>
                        </span>
                    </div>
                    <span class="relative inline-flex h-6 w-11 items-center shrink-0 rounded-full transition-colors @(_thematicMaps ? "bg-accent-500" : "bg-ink-200")">
                        <span class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform @(_thematicMaps ? "translate-x-5" : "")"></span>
                    </span>
                </div>
            </div>

            <div>
                <label class="label">
                    Island setup
                    <span class="text-ink-500 font-normal normal-case tracking-normal">— @EffectiveBoardCount board@(EffectiveBoardCount == 1 ? "" : "s")@(_thematicMaps ? " · thematic" : "")</span>
                </label>
                <IslandSetupPicker @bind-Value="_islandSetupId" PlayerCount="EffectiveBoardCount" Thematic="_thematicMaps"/>
                <FieldError For="IslandSetupId" Errors="@_errors"/>
                @if (_thematicMaps && !ThematicAvailableForBoardCount)
                {
                    <p class="mt-2 text-xs text-red-600">No thematic layout exists for @EffectiveBoardCount boards. Turn off <em>Thematic maps</em> or @(_extraBoard ? "disable the extra board" : "enable the extra board").</p>
                }
            </div>

            <div class="grid md:grid-cols-2 gap-4">
                @* Scenario picker (button) *@
                <div>
                    <label class="label">Scenario</label>
                    @{
                        var scen = ScenarioFor(_scenarioId);
                    }
                    <button type="button"
                            @onclick="OpenScenarioPicker"
                            class="w-full h-12 flex items-center justify-between gap-3 px-3 rounded-lg border border-ink-200 bg-white hover:bg-ink-50 transition-colors text-left
                                   focus:outline-none focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30">
                        <div class="flex items-center gap-2 min-w-0">
                            <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg @(scen is not null ? "bg-accent-100 text-accent-700" : "bg-ink-100 text-ink-500") shrink-0">
                                <Icon Name="book" Class="w-4 h-4"/>
                            </span>
                            @if (scen is not null)
                            {
                                <div class="min-w-0">
                                    <div class="text-sm font-semibold text-ink-900 truncate">@scen.Name</div>
                                    <div class="text-[11px] text-ink-500">+@scen.Difficulty difficulty</div>
                                </div>
                            }
                            else
                            {
                                <span class="text-sm text-ink-500 truncate min-w-0 flex-1">No scenario — standard game</span>
                            }
                        </div>
                        <Icon Name="edit" Class="w-3.5 h-3.5 text-ink-400 shrink-0"/>
                    </button>
                </div>
                <div>
                    <label class="label">Date played</label>
                    <input type="date" class="input h-12" @bind="_datePlayed"/>
                </div>
            </div>

            @* Adversaries *@
            <div>
                <div class="flex items-center justify-between mb-2">
                    <label class="label mb-0">Adversaries</label>
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="OpenAdversaryPickerForNew">
                        <Icon Name="plus" Class="w-3.5 h-3.5"/> Add adversary
                    </button>
                </div>

                @if (_adversaries.Count == 0)
                {
                    <div class="rounded-lg border border-dashed border-ink-300 px-4 py-3 text-sm text-ink-500 bg-ink-50/40">
                        No adversary — tutorial / freeplay game.
                    </div>
                }
                else
                {
                    <div class="grid sm:grid-cols-2 gap-2.5">
                        @for (var i = 0; i < _adversaries.Count; i++)
                        {
                            var idx = i;
                            var item = _adversaries[idx];
                            var adv = AdversaryFor(item.AdversaryId);
                            var mode = adv?.Modes.FirstOrDefault(m => m.Level == item.Level);

                            <div class="flex items-center gap-3 rounded-lg border border-ink-200 bg-white p-3">
                                <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent-50 text-accent-700 shrink-0">
                                    <Icon Name="shield" Class="w-4 h-4"/>
                                </span>
                                <button type="button" @onclick="() => OpenAdversaryPickerFor(idx)"
                                        class="flex-1 text-left min-w-0 hover:underline">
                                    <div class="text-sm font-semibold text-ink-900 truncate">@(adv?.Name ?? "Select adversary…")</div>
                                    <div class="text-[11px] text-ink-500">
                                        Level @item.Level · +@(mode?.Difficulty ?? 0) difficulty
                                    </div>
                                </button>
                                <button type="button"
                                        class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-ink-400 hover:bg-red-50 hover:text-red-600 transition-colors"
                                        @onclick="() => _adversaries.RemoveAt(idx)"
                                        aria-label="Remove adversary">
                                    <Icon Name="trash" Class="w-4 h-4"/>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>

            @* Difficulty modifier *@
            <div class="grid sm:grid-cols-[1fr_8rem] gap-3 items-end">
                <div>
                    <label class="label flex items-center gap-1.5">
                        <span>Difficulty modifier</span>
                        <InfoHint>
                            Manual <strong class="text-ink-900">+/− adjustment</strong> for homemade variants or anything the standard formula doesn't cover. Leave at 0 for ordinary games. Allowed range: @GameRestrictions.DifficultyModifierMin to +@GameRestrictions.DifficultyModifierMax.
                        </InfoHint>
                    </label>
                    <p class="text-[11px] text-ink-500 m-0">Added directly to total difficulty.</p>
                </div>
                <div>
                    <input type="number" class="input h-12 w-full" @bind="_difficultyModifier"
                           min="@GameRestrictions.DifficultyModifierMin" max="@GameRestrictions.DifficultyModifierMax"/>
                    <FieldError For="DifficultyModifier" Errors="@_errors"/>
                </div>
            </div>

            @* Difficulty hero *@
            <div class="rounded-xl bg-gradient-to-br from-accent-50 to-accent-100/60 border border-accent-200 p-5 flex items-center justify-between gap-4">
                <div>
                    <div class="text-[11px] uppercase tracking-wider text-accent-700 font-semibold">Total difficulty</div>
                    <div class="text-4xl font-bold text-accent-900 mt-1 leading-none" style="font-family: var(--font-serif);">@ComputedDifficulty</div>
                </div>
                <div class="text-xs text-accent-800/70 text-right space-y-0.5">
                    @if (_adversaries.Count == 0 && string.IsNullOrEmpty(_scenarioId) && !_extraBoard && !_thematicMaps && _difficultyModifier == 0)
                    {
                        <div>Tutorial / freeplay</div>
                    }
                    else
                    {
                        @foreach (var a in _adversaries.Where(a => !string.IsNullOrEmpty(a.AdversaryId)))
                        {
                            var adv = AdversaryFor(a.AdversaryId);
                            var mode = adv?.Modes.FirstOrDefault(m => m.Level == a.Level);
                            <div>@(adv?.Name ?? "Adversary") L@(a.Level) <span class="text-accent-700/60">+@(mode?.Difficulty ?? 0)</span></div>
                        }
                        @if (!string.IsNullOrEmpty(_scenarioId))
                        {
                            var sc = ScenarioFor(_scenarioId);
                            <div>@(sc?.Name ?? "Scenario") <span class="text-accent-700/60">+@(sc?.Difficulty ?? 0)</span></div>
                        }
                        @if (_extraBoard)
                        {
                            <div>Extra board <span class="text-accent-700/60">+@GameRestrictions.ExtraBoardDifficultyBonus</span></div>
                        }
                        @if (_thematicMaps)
                        {
                            <div>Thematic maps <span class="text-accent-700/60">+@GameRestrictions.ThematicMapsDifficultyBonus</span></div>
                        }
                        @if (_difficultyModifier != 0)
                        {
                            <div>Modifier <span class="text-accent-700/60">@(_difficultyModifier > 0 ? "+" : "")@_difficultyModifier</span></div>
                        }
                    }
                </div>
            </div>
        </div>
    </section>

    @* ============================== RESULT (optional, distinct) ============================== *@
    <section class="mb-8">
        <div class="flex items-end justify-between mb-3">
            <div>
                <span class="eyebrow">Step 3 · optional</span>
                <h2 class="text-xl font-semibold mt-1" style="font-family: var(--font-serif);">Outcome</h2>
                <p class="text-sm text-ink-500">Skip this to save a draft, or fill it in to record a finished match.</p>
            </div>
        </div>

        <div class="result-card relative rounded-2xl border transition-all
                    @(_includeResult
                        ? "border-amber-300 bg-gradient-to-br from-amber-50 via-white to-amber-50/40 shadow-sm"
                        : "border-ink-200 bg-ink-50/40")">
            <div class="px-5 md:px-6 py-4 flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                    <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl @(_includeResult ? "bg-amber-100 text-amber-700" : "bg-ink-100 text-ink-500")">
                        <Icon Name="trophy" Class="w-5 h-5"/>
                    </span>
                    <div>
                        <div class="text-sm font-semibold text-ink-900">Did you finish this game?</div>
                        <div class="text-xs text-ink-500">@(_includeResult ? "Recording outcome below." : "Toggle on to record victory/defeat and stats.")</div>
                    </div>
                </div>
                @* Toggle switch *@
                <label class="inline-flex items-center cursor-pointer select-none">
                    <span class="text-xs font-medium text-ink-700 mr-2">@(_includeResult ? "Yes" : "Skip")</span>
                    <span class="relative inline-flex h-6 w-11 items-center">
                        <input type="checkbox" class="sr-only peer" @bind="_includeResult"/>
                        <span class="absolute inset-0 rounded-full bg-ink-200 peer-checked:bg-amber-500 transition-colors"></span>
                        <span class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform peer-checked:translate-x-5"></span>
                    </span>
                </label>
            </div>

            @if (_includeResult)
            {
                <div class="border-t border-amber-200/60 bg-white/60 px-5 md:px-6 py-5 space-y-5">
                    @* Win/Defeat hero choice *@
                    <div class="grid grid-cols-2 gap-2">
                        <button type="button" @onclick="() => _resultWin = true"
                                class="@(_resultWin ? "border-accent-500 bg-accent-50 text-accent-800 ring-2 ring-accent-500/30" : "border-ink-200 bg-white text-ink-600 hover:border-ink-300")
                                       flex items-center justify-center gap-2 rounded-xl border px-4 py-3 transition-all">
                            <Icon Name="trophy" Class="w-5 h-5"/>
                            <span class="font-semibold">Victory</span>
                        </button>
                        <button type="button" @onclick="() => _resultWin = false"
                                class="@(!_resultWin ? "border-red-400 bg-red-50 text-red-800 ring-2 ring-red-300/40" : "border-ink-200 bg-white text-ink-600 hover:border-ink-300")
                                       flex items-center justify-center gap-2 rounded-xl border px-4 py-3 transition-all">
                            <Icon Name="x" Class="w-5 h-5"/>
                            <span class="font-semibold">Defeat</span>
                        </button>
                    </div>

                    @* Stats grid *@
                    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
                        <div>
                            <label class="label flex items-center gap-1.5">
                                <span>Terror level</span>
                                <InfoHint>
                                    <strong class="text-ink-900">Terror level reached</strong> when the game ended. Tracked for reference but does not affect the score.
                                </InfoHint>
                            </label>
                            <select class="select" @bind="_resultTerror">
                                @foreach (var t in Enum.GetValues<TerrorLevel>())
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                            <FieldError For="Result.TerrorLevel" Errors="@_errors"/>
                        </div>
                        <div>
                            <label class="label">Duration (min)</label>
                            <input type="number" class="input" @bind="_resultDuration" min="0"/>
                            <FieldError For="Result.Duration" Errors="@_errors"/>
                        </div>
                        <div>
                            <label class="label flex items-center gap-1.5">
                                <span>Dahan remaining</span>
                                <InfoHint>
                                    <strong class="text-ink-900">Dahan tokens left on the island</strong> when the game ends. Every <span class="text-ink-900">@_players.Count</span> Dahan adds <span class="text-ink-900">+1</span> to your score.
                                </InfoHint>
                            </label>
                            <input type="number" class="input" @bind="_resultDahan" min="0"/>
                            <FieldError For="Result.Dahan" Errors="@_errors"/>
                        </div>
                        <div>
                            <label class="label flex items-center gap-1.5">
                                <span>Blight on island</span>
                                <InfoHint>
                                    <strong class="text-ink-900">Total Blight tokens on the island</strong> when the game ends. Every <span class="text-ink-900">@_players.Count</span> Blight subtracts <span class="text-ink-900">−1</span> from your score.
                                </InfoHint>
                            </label>
                            <input type="number" class="input" @bind="_resultBlight" min="0"/>
                            <FieldError For="Result.Blight" Errors="@_errors"/>
                        </div>
                        <div>
                            <label class="label flex items-center gap-1.5">
                                @if (_resultWin)
                                {
                                    <span>Cards remaining in invader deck</span>
                                    <InfoHint>
                                        Cards <strong class="text-ink-900">left undrawn</strong> in the invader deck at the end. Each remaining card adds <span class="text-ink-900">+2</span> to your score.
                                    </InfoHint>
                                }
                                else
                                {
                                    <span>Enemy cards used</span>
                                    <InfoHint>
                                        Invader cards <strong class="text-ink-900">played or discarded</strong> during the game (not left in the deck). Each used card adds <span class="text-ink-900">+1</span> to your score.
                                    </InfoHint>
                                }
                            </label>
                            <input type="number" class="input" @bind="_resultCards" min="0"/>
                            <FieldError For="Result.Cards" Errors="@_errors"/>
                        </div>
                        <div>
                            <label class="label flex items-center gap-1.5">
                                <span>Score modifier</span>
                                <InfoHint>
                                    Manual <strong class="text-ink-900">+/− adjustment</strong> for unusual circumstances — homemade variants, scenario-specific bonuses, or anything the standard formula doesn't capture. Leave at 0 for ordinary games.
                                </InfoHint>
                            </label>
                            <input type="number" class="input" @bind="_resultScoreMod"/>
                            <FieldError For="Result.ScoreModifier" Errors="@_errors"/>
                        </div>
                    </div>

                    @* Live score breakdown *@
                    @{
                        var players = Math.Max(1, _players.Count);
                        var diffPart = _resultWin ? 5 * ComputedDifficulty : 2 * ComputedDifficulty;
                        var cardsPart = _resultWin ? 2 * _resultCards : _resultCards;
                        var dahanPart = _resultDahan / players;
                        var blightPart = _resultBlight / players;
                    }
                    <div class="rounded-xl bg-gradient-to-br @(_resultWin ? "from-accent-50 to-accent-100/60 border-accent-200" : "from-red-50 to-red-100/40 border-red-200") border p-5 flex items-center justify-between gap-4">
                        <div>
                            <div class="text-[11px] uppercase tracking-wider @(_resultWin ? "text-accent-700" : "text-red-700") font-semibold">Score preview</div>
                            <div class="text-4xl font-bold @(_resultWin ? "text-accent-900" : "text-red-900") mt-1 leading-none" style="font-family: var(--font-serif);">@ComputedScore</div>
                            <div class="mt-1 text-[11px] @(_resultWin ? "text-accent-800/70" : "text-red-800/70")">@(_resultWin ? "Victory formula" : "Defeat formula")</div>
                        </div>
                        <div class="text-xs @(_resultWin ? "text-accent-800/80" : "text-red-800/80") text-right space-y-0.5 tabular-nums">
                            <div>@(_resultWin ? "5 ×" : "2 ×") difficulty (@ComputedDifficulty) <span class="opacity-70">@FormatSigned(diffPart)</span></div>
                            @if (_resultWin)
                            {
                                <div>Victory bonus <span class="opacity-70">+10</span></div>
                                <div>2 × cards remaining (@_resultCards) <span class="opacity-70">@FormatSigned(cardsPart)</span></div>
                            }
                            else
                            {
                                <div>Cards used (@_resultCards) <span class="opacity-70">@FormatSigned(cardsPart)</span></div>
                            }
                            <div>Dahan @_resultDahan / @players <span class="opacity-70">@FormatSigned(dahanPart)</span></div>
                            <div>Blight @_resultBlight / @players <span class="opacity-70">@FormatSigned(-blightPart)</span></div>
                            @if (_resultScoreMod != 0)
                            {
                                <div>Modifier <span class="opacity-70">@FormatSigned(_resultScoreMod)</span></div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    @* ============================== NOTE ============================== *@
    <section class="mb-8">
        <div class="surface">
            <div class="surface-head"><h2 class="text-base font-semibold">Note</h2></div>
            <div class="surface-body">
                <textarea class="textarea" rows="3" @bind="_note" placeholder="Optional game notes — anything memorable from the match…"></textarea>
                <FieldError For="Note" Errors="@_errors"/>
            </div>
        </div>
    </section>

    @* ============================== ACTIONS ============================== *@
    <div class="sticky bottom-3 z-10">
        <div class="surface px-5 py-3 flex flex-wrap items-center gap-2 shadow-sm">
            <div class="text-xs text-ink-500 mr-auto">
                @if (_includeResult) { <span>Saving as a <strong class="text-ink-800">finished game</strong>.</span> }
                else { <span>Saving as a <strong class="text-ink-800">draft</strong> — fill in outcome anytime.</span> }
            </div>
            @if (_includeResult)
            {
                <button class="btn btn-primary" @onclick="SaveCompleted" disabled="@_saving">
                    <Icon Name="check-circle" Class="w-4 h-4"/> Save completed game
                </button>
            }
            else
            {
                <button class="btn btn-primary" @onclick="SaveDraft" disabled="@_saving">
                    <Icon Name="save" Class="w-4 h-4"/> Save as draft
                </button>
            }
            <a href="/app/games" class="btn btn-ghost">Cancel</a>
        </div>
    </div>

    </div> @* /lg:min-w-0 (form column) *@

    @* ============================== STICKY SUMMARY (lg+) ============================== *@
    @* Sticky directly on the grid item with self-start so it has room to stick within
       the grid row (which is taller than the aside thanks to the form column). *@
    <aside class="hidden lg:block lg:sticky lg:top-6 lg:self-start">
            <div class="surface overflow-hidden">
                @* Difficulty hero *@
                <div class="bg-gradient-to-br from-accent-700 to-accent-900 text-white px-5 py-4">
                    <div class="text-[10px] uppercase tracking-wider text-accent-100 font-semibold">Total difficulty</div>
                    <div class="text-3xl font-bold leading-none mt-1" style="font-family: var(--font-serif);">@ComputedDifficulty</div>
                    @if (_adversaries.Count == 0 && string.IsNullOrEmpty(_scenarioId))
                    {
                        <div class="text-[11px] text-accent-100/90 mt-1.5">Tutorial / freeplay</div>
                    }
                </div>

                @* Players *@
                <div class="px-5 py-4">
                    <div class="text-[10px] uppercase tracking-wider text-ink-500 mb-2 font-medium">
                        Players · @_players.Count
                    </div>
                    <ul class="space-y-2">
                        @for (var i = 0; i < _players.Count; i++)
                        {
                            var sp = _players[i];
                            var spirit = SpiritFor(sp.SpiritId);
                            var spiritDetail = spirit is null ? null : SpiritDetails.For(spirit.Id);
                            var color = spiritDetail?.ColorHex ?? "#78716c";
                            var board = BoardFor(sp.BoardId);
                            var boardDetail = board is null ? null : BoardDetails.For(board.Id);
                            var aspect = string.IsNullOrEmpty(sp.AspectId)
                                ? null
                                : GameData.Aspects.FirstOrDefault(a => a.Id.Value == sp.AspectId);

                            <li class="flex items-start gap-2 text-xs">
                                <span class="inline-block h-7 w-1 rounded-full shrink-0 mt-0.5" style="background-color: @color;"></span>
                                <div class="min-w-0 flex-1">
                                    <div class="text-ink-900 truncate font-medium">
                                        @(spirit?.Name ?? "Spirit not chosen")@if (aspect is not null) { <span class="text-ink-500 font-normal"> · @aspect.Name</span> }
                                    </div>
                                    <div class="text-[11px] text-ink-500 truncate">
                                        @if (board is not null)
                                        {
                                            <span>Board @(boardDetail?.Letter ?? board.Name[^1..])</span>
                                            @if (boardDetail is not null)
                                            {
                                                <span> · @boardDetail.ThematicName</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="italic">No board</span>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>

                @* Adversaries *@
                @{
                    var summaryAdvs = _adversaries
                        .Select(a => new { Adv = AdversaryFor(a.AdversaryId), a.Level })
                        .Where(x => x.Adv is not null)
                        .ToList();
                }
                @if (summaryAdvs.Count > 0)
                {
                    <div class="px-5 py-4 border-t border-ink-100">
                        <div class="text-[10px] uppercase tracking-wider text-ink-500 mb-2 font-medium">
                            @(summaryAdvs.Count > 1 ? "Adversaries" : "Adversary")
                        </div>
                        <ul class="space-y-1.5">
                            @foreach (var a in summaryAdvs)
                            {
                                var mode = a.Adv!.Modes.FirstOrDefault(m => m.Level == a.Level);
                                <li class="flex items-center justify-between gap-2 text-xs">
                                    <span class="text-ink-900 truncate">@a.Adv.Name</span>
                                    <span class="text-ink-500 shrink-0 font-medium tabular-nums">L@(a.Level) · +@(mode?.Difficulty ?? 0)</span>
                                </li>
                            }
                        </ul>
                    </div>
                }

                @* Scenario *@
                @if (ScenarioFor(_scenarioId) is { } summaryScenario)
                {
                    <div class="px-5 py-4 border-t border-ink-100">
                        <div class="text-[10px] uppercase tracking-wider text-ink-500 mb-2 font-medium">Scenario</div>
                        <div class="flex items-center justify-between gap-2 text-xs">
                            <span class="text-ink-900 truncate">@summaryScenario.Name</span>
                            <span class="text-ink-500 shrink-0 font-medium tabular-nums">+@summaryScenario.Difficulty</span>
                        </div>
                    </div>
                }

                @* Date played *@
                <div class="px-5 py-4 border-t border-ink-100">
                    <div class="text-[10px] uppercase tracking-wider text-ink-500 mb-1 font-medium">Date played</div>
                    <div class="text-xs text-ink-700">@_datePlayed.ToString("MMMM d, yyyy")</div>
                </div>

                @* Outcome (when toggled on) *@
                @if (_includeResult)
                {
                    <div class="px-5 py-4 border-t border-ink-100">
                        <div class="text-[10px] uppercase tracking-wider text-ink-500 mb-2 font-medium">Outcome</div>
                        <div class="flex items-center justify-between gap-2">
                            <span class="badge @(_resultWin ? "badge-success" : "badge-danger")">
                                <Icon Name="@(_resultWin ? "trophy" : "x")" Class="w-3 h-3"/>
                                @(_resultWin ? "Victory" : "Defeat")
                            </span>
                            <div class="text-right">
                                <div class="text-[10px] uppercase tracking-wider text-ink-500 font-medium">Score</div>
                                <div class="text-xl font-semibold text-ink-900 leading-none tabular-nums" style="font-family: var(--font-serif);">@ComputedScore</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
    </aside>

    </div> @* /lg:grid wrapper *@
}

@* ============================== MODALS ============================== *@
<SpiritPickerModal @ref="_spiritPicker" OnSelected="OnSpiritPicked"/>
<BoardPickerModal @ref="_boardPicker" OnSelected="OnBoardPicked" BoardsTaken="@BoardsTakenForCurrentEdit()" AllowReuse="true"/>
<AdversaryPickerModal @ref="_adversaryPicker" OnSelected="OnAdversaryPicked"/>
<ScenarioPickerModal @ref="_scenarioPicker" OnSelected="OnScenarioPicked"/>

@code {
    private bool _loading = true;
    private bool _saving;
    private string? _message;
    private string _alertType = "danger";
    private FormErrors _errors = FormErrors.Empty;

    private void ApplyErrors(Domain.Results.Result result)
    {
        _errors = FormErrors.FromResult(result);
        if (_errors.Any)
        {
            _message = null;
        }
        else
        {
            _message = result.Error.Message;
            _alertType = "danger";
        }
    }

    private string _islandSetupId = "";
    private string? _scenarioId;
    private DateTime _datePlayed = DateTime.Today;

    private SpiritPickerModal _spiritPicker = default!;
    private BoardPickerModal _boardPicker = default!;
    private AdversaryPickerModal _adversaryPicker = default!;
    private ScenarioPickerModal _scenarioPicker = default!;

    private int _editingSpiritIndex = -1;
    private int _editingBoardIndex = -1;
    private int _editingAdversaryIndex = -1; // -1 means "add new"

    [CascadingParameter(Name = "OwnedExpansions")]
    public IReadOnlyList<ExpansionId>? OwnedExpansions { get; set; }

    private int ComputedDifficulty =>
        Domain.Services.DifficultyCalculator.Compute(
            scenarioDifficulty: string.IsNullOrEmpty(_scenarioId) ? 0 : ScenarioFor(_scenarioId)?.Difficulty ?? 0,
            adversaryDifficulties: _adversaries
                .Where(a => !string.IsNullOrEmpty(a.AdversaryId))
                .Select(a => AdversaryFor(a.AdversaryId)?.Modes.FirstOrDefault(m => m.Level == a.Level)?.Difficulty ?? 0),
            usesExtraBoard: _extraBoard && ExtraBoardAllowed,
            usesThematicMaps: _thematicMaps,
            modifier: _difficultyModifier);

    private int ComputedScore =>
        Domain.Services.ScoreCalculator.Compute(
            win: _resultWin,
            difficulty: ComputedDifficulty,
            dahan: _resultDahan,
            cards: _resultCards,
            blight: _resultBlight,
            playerCount: _players.Count,
            scoreModifier: _resultScoreMod);

    private bool ExtraBoardAllowed => _players.Count <= GameRestrictions.MaximumPlayersForExtraBoard;
    private int EffectiveBoardCount => _players.Count + (_extraBoard && ExtraBoardAllowed ? 1 : 0);
    private bool ThematicAvailableForBoardCount =>
        GameData.IslandSetups.Any(s => s.IsThematic && s.NumberOfPlayers == EffectiveBoardCount);

    private void ToggleExtraBoard()
    {
        if (!ExtraBoardAllowed) return;
        _extraBoard = !_extraBoard;
    }

    private void OnExtraBoardKey(KeyboardEventArgs e)
    {
        if (e.Key is " " or "Enter") ToggleExtraBoard();
    }

    private void OnThematicMapsKey(KeyboardEventArgs e)
    {
        if (e.Key is " " or "Enter") _thematicMaps = !_thematicMaps;
    }

    private static string FormatSigned(int n) => n >= 0 ? $"+{n}" : n.ToString();

    private List<PlayerFormItem> _players = [new()];
    private List<Application.Features.Friendships.FriendResponse> _friends = [];
    private List<Application.Features.Players.ListPlayersResponse> _localPlayers = [];

    private List<AdversaryFormItem> _adversaries = [];

    private bool _extraBoard;
    private bool _thematicMaps;
    private int _difficultyModifier;

    private bool _includeResult;
    private bool _resultWin = true;
    private TerrorLevel _resultTerror = TerrorLevel.First;
    private int _resultDuration = 60;
    private int _resultDahan;
    private int _resultBlight;
    private int _resultCards;
    private int _resultScoreMod;
    private string? _note;

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser.UserId is not { } userId) return;

        var friendsResult = await Mediator.Send(new Application.Features.Friendships.ListFriendsQuery(userId));
        var playersResult = await Mediator.Send(new Application.Features.Players.ListPlayersQuery(userId));

        if (friendsResult.IsSuccess) _friends = friendsResult.Value;
        if (playersResult.IsSuccess) _localPlayers = playersResult.Value;

        _loading = false;
    }

    @* ============== Player editing ============== *@
    private void AddPlayer()
    {
        _players.Add(new PlayerFormItem());
        if (!ExtraBoardAllowed) _extraBoard = false;
    }

    private void RemovePlayer(int idx) => _players.RemoveAt(idx);

    private void OnAssigneeChanged(int idx, string value)
    {
        _players[idx].AssignedTo = value;
    }

    private void SelectAspect(int idx, string? aspectId)
    {
        _players[idx].AspectId = aspectId ?? "";
    }

    private IReadOnlyList<Aspect> GetAspectsForSpirit(string spiritId)
    {
        if (string.IsNullOrEmpty(spiritId)) { return []; }
        var aspects = GameData.GetAspectsForSpirit(new SpiritId(spiritId));
        if (OwnedExpansions is null) { return aspects; }
        return aspects.Where(a => OwnedExpansions.Contains(a.ExpansionId)).ToList();
    }

    @* ============== Spirit picker ============== *@
    private void OpenSpiritPicker(int idx)
    {
        _editingSpiritIndex = idx;
        _spiritPicker.Show(_players[idx].SpiritId);
    }

    private void OnSpiritPicked(Spirit spirit)
    {
        if (_editingSpiritIndex < 0 || _editingSpiritIndex >= _players.Count) return;
        var p = _players[_editingSpiritIndex];
        if (p.SpiritId != spirit.Id.Value)
        {
            p.SpiritId = spirit.Id.Value;
            p.AspectId = ""; // reset aspect when spirit changes
        }
        _editingSpiritIndex = -1;
        StateHasChanged();
    }

    @* ============== Board picker ============== *@
    private void OpenBoardPicker(int idx)
    {
        _editingBoardIndex = idx;
        _boardPicker.Show(_players[idx].BoardId);
    }

    private IReadOnlyCollection<string> BoardsTakenForCurrentEdit()
    {
        if (_editingBoardIndex < 0) { return []; }
        return _players
            .Where((_, i) => i != _editingBoardIndex)
            .Select(p => p.BoardId)
            .Where(id => !string.IsNullOrEmpty(id))
            .ToList();
    }

    private void OnBoardPicked(Board board)
    {
        if (_editingBoardIndex < 0 || _editingBoardIndex >= _players.Count) return;
        _players[_editingBoardIndex].BoardId = board.Id.Value;
        _editingBoardIndex = -1;
        StateHasChanged();
    }

    @* ============== Adversary picker ============== *@
    private void OpenAdversaryPickerForNew()
    {
        _editingAdversaryIndex = -1;
        _adversaryPicker.Show();
    }

    private void OpenAdversaryPickerFor(int idx)
    {
        _editingAdversaryIndex = idx;
        _adversaryPicker.Show();
    }

    private void OnAdversaryPicked((Adversary adversary, int level) pick)
    {
        if (_editingAdversaryIndex >= 0 && _editingAdversaryIndex < _adversaries.Count)
        {
            _adversaries[_editingAdversaryIndex] = new AdversaryFormItem
            {
                AdversaryId = pick.adversary.Id.Value,
                Level = pick.level
            };
        }
        else
        {
            _adversaries.Add(new AdversaryFormItem
            {
                AdversaryId = pick.adversary.Id.Value,
                Level = pick.level
            });
        }
        _editingAdversaryIndex = -1;
        StateHasChanged();
    }

    @* ============== Scenario picker ============== *@
    private void OpenScenarioPicker() => _scenarioPicker.Show(_scenarioId);

    private void OnScenarioPicked(Scenario? scenario)
    {
        _scenarioId = scenario?.Id.Value;
        StateHasChanged();
    }

    @* ============== Lookups ============== *@
    private static Spirit? SpiritFor(string id) =>
        string.IsNullOrEmpty(id) ? null : GameData.Spirits.FirstOrDefault(x => x.Id.Value == id);

    private static Board? BoardFor(string id) =>
        string.IsNullOrEmpty(id) ? null : GameData.Boards.FirstOrDefault(x => x.Id.Value == id);

    private static Adversary? AdversaryFor(string id) =>
        string.IsNullOrEmpty(id) ? null : GameData.Adversaries.FirstOrDefault(x => x.Id.Value == id);

    private static Scenario? ScenarioFor(string? id) =>
        string.IsNullOrEmpty(id) ? null : GameData.Scenarios.FirstOrDefault(x => x.Id.Value == id);

    private string ScenarioName() => ScenarioFor(_scenarioId)?.Name ?? "—";

    @* ============== Save ============== *@
    private List<Application.Features.Games.Dtos.GamePlayerDto> BuildPlayerDtos()
    {
        return _players.Select(p =>
        {
            Guid? userId = null;
            Guid? playerId = null;

            if (p.AssignedTo == "me")
                userId = CurrentUser.UserId;
            else if (p.AssignedTo.StartsWith("friend:"))
                userId = Guid.Parse(p.AssignedTo["friend:".Length..]);
            else if (p.AssignedTo.StartsWith("player:"))
                playerId = Guid.Parse(p.AssignedTo["player:".Length..]);

            return new Application.Features.Games.Dtos.GamePlayerDto(
                p.SpiritId, string.IsNullOrEmpty(p.AspectId) ? null : p.AspectId,
                p.BoardId, userId, playerId);
        }).ToList();
    }

    private List<Application.Features.Games.Dtos.GameAdversaryDto> BuildAdversaryDtos()
        => _adversaries.Select(a => new Application.Features.Games.Dtos.GameAdversaryDto(a.AdversaryId, a.Level)).ToList();

    private async Task SaveDraft()
    {
        _saving = true;
        var cmd = new Application.Features.Games.DraftGameCommand(
            CurrentUser.UserId!.Value,
            new DateTimeOffset(DateTime.SpecifyKind(_datePlayed, DateTimeKind.Unspecified), TimeSpan.Zero),
            _islandSetupId,
            _extraBoard && ExtraBoardAllowed,
            _thematicMaps,
            _difficultyModifier,
            BuildPlayerDtos(), BuildAdversaryDtos(),
            string.IsNullOrEmpty(_scenarioId) ? null : _scenarioId,
            string.IsNullOrEmpty(_note) ? null : _note);

        var result = await Mediator.Send(cmd);
        _saving = false;

        if (result.IsSuccess)
            Nav.NavigateTo("/app/games");
        else
            ApplyErrors(result);
    }

    private async Task SaveCompleted()
    {
        _saving = true;
        var resultDto = new Application.Features.Games.Dtos.GameResultDto(
            _resultWin, TimeSpan.FromMinutes(_resultDuration),
            _resultCards, _resultTerror, _resultBlight, _resultDahan, _resultScoreMod);

        var cmd = new Application.Features.Games.CreateGameCommand(
            CurrentUser.UserId!.Value,
            new DateTimeOffset(DateTime.SpecifyKind(_datePlayed, DateTimeKind.Unspecified), TimeSpan.Zero),
            _islandSetupId,
            _extraBoard && ExtraBoardAllowed,
            _thematicMaps,
            _difficultyModifier,
            BuildPlayerDtos(), BuildAdversaryDtos(),
            string.IsNullOrEmpty(_scenarioId) ? null : _scenarioId,
            resultDto,
            string.IsNullOrEmpty(_note) ? null : _note);

        var result = await Mediator.Send(cmd);
        _saving = false;

        if (result.IsSuccess)
            Nav.NavigateTo("/app/games");
        else
            ApplyErrors(result);
    }

    private class PlayerFormItem
    {
        public string SpiritId { get; set; } = "";
        public string? AspectId { get; set; }
        public string BoardId { get; set; } = "";
        public string AssignedTo { get; set; } = "me";
    }

    private class AdversaryFormItem
    {
        public string AdversaryId { get; set; } = "";
        public int Level { get; set; }
    }
}
