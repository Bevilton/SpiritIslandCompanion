@* Read-only summary of a completed game's result. Uses the same visual treatment
   as GameResultEditor's score preview so the page reads consistently before and
   after the user records the outcome. *@

@if (Result is not null)
{
    var win = Result.Win;
    <section class="rounded-2xl bg-gradient-to-br @(win ? "from-accent-50 to-accent-100/60 border-accent-200" : "from-red-50 to-red-100/40 border-red-200") border overflow-hidden">
        <div class="px-5 md:px-6 py-5 flex flex-wrap items-center justify-between gap-4 border-b @(win ? "border-accent-200/60" : "border-red-200/60")">
            <div class="flex items-center gap-3">
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl @(win ? "bg-accent-600 text-white" : "bg-red-500 text-white")">
                    <Icon Name="@(win ? "trophy" : "x")" Class="w-6 h-6"/>
                </span>
                <div>
                    <div class="text-[11px] uppercase tracking-wider @(win ? "text-accent-700" : "text-red-700") font-semibold">Outcome</div>
                    <div class="text-2xl font-bold @(win ? "text-accent-900" : "text-red-900") leading-none mt-1" style="font-family: var(--font-serif);">@(win ? "Victory" : "Defeat")</div>
                </div>
            </div>
            <div class="text-right">
                <div class="text-[11px] uppercase tracking-wider @(win ? "text-accent-700" : "text-red-700") font-semibold">Score</div>
                <div class="text-4xl font-bold @(win ? "text-accent-900" : "text-red-900") leading-none mt-1 tabular-nums" style="font-family: var(--font-serif);">@Result.Score</div>
            </div>
        </div>

        <dl class="grid grid-cols-2 md:grid-cols-3 gap-x-5 gap-y-3 px-5 md:px-6 py-5 text-sm">
            <div>
                <dt class="text-[10px] uppercase tracking-wide text-ink-500 font-medium">Terror level</dt>
                <dd class="mt-0.5 text-ink-900 font-medium">@Result.TerrorLevel</dd>
            </div>
            <div>
                <dt class="text-[10px] uppercase tracking-wide text-ink-500 font-medium">Duration</dt>
                <dd class="mt-0.5 text-ink-900 font-medium">@FormatDuration(Result.Duration)</dd>
            </div>
            <div>
                <dt class="text-[10px] uppercase tracking-wide text-ink-500 font-medium">@(win ? "Cards remaining" : "Cards used")</dt>
                <dd class="mt-0.5 text-ink-900 font-medium tabular-nums">@Result.Cards</dd>
            </div>
            <div>
                <dt class="text-[10px] uppercase tracking-wide text-ink-500 font-medium">Dahan remaining</dt>
                <dd class="mt-0.5 text-ink-900 font-medium tabular-nums">@Result.Dahan</dd>
            </div>
            <div>
                <dt class="text-[10px] uppercase tracking-wide text-ink-500 font-medium">Blight on island</dt>
                <dd class="mt-0.5 text-ink-900 font-medium tabular-nums">@Result.Blight</dd>
            </div>
            @if (Result.ScoreModifier != 0)
            {
                <div>
                    <dt class="text-[10px] uppercase tracking-wide text-ink-500 font-medium">Score modifier</dt>
                    <dd class="mt-0.5 text-ink-900 font-medium tabular-nums">@FormatSigned(Result.ScoreModifier)</dd>
                </div>
            }
        </dl>
    </section>
}

@code {
    [Parameter, EditorRequired] public Application.Features.Games.Dtos.GameResultResponse? Result { get; set; }

    private static string FormatSigned(int n) => n >= 0 ? $"+{n}" : n.ToString();

    private static string FormatDuration(TimeSpan d)
    {
        if (d.TotalHours >= 1)
        {
            return d.Minutes == 0
                ? $"{(int)d.TotalHours} h"
                : $"{(int)d.TotalHours} h {d.Minutes} min";
        }
        return $"{(int)d.TotalMinutes} min";
    }
}
