@* Read-only visual summary of how a recorded game was set up — island layout,
   scenario, adversaries — plus a difficulty hero. Companion to GamePlayerCard. *@

@{
    var setup = GameLookups.IslandSetupFor(IslandSetupId);
    var scenario = GameLookups.ScenarioFor(ScenarioId);
    var adversaries = Adversaries
        .Select(a => (Item: a, Adversary: GameLookups.AdversaryFor(a.AdversaryId)))
        .Where(x => x.Adversary is not null)
        .ToList();

    var isFreeplay = adversaries.Count == 0 && scenario is null && !ExtraBoard && !ThematicMaps && DifficultyModifier == 0;
}

<section class="surface overflow-hidden">
    @* Difficulty hero — same gradient as the new game form *@
    <div class="bg-gradient-to-br from-accent-50 to-accent-100/60 border-b border-accent-200 p-5 flex items-center justify-between gap-4">
        <div>
            <div class="text-[11px] uppercase tracking-wider text-accent-700 font-semibold">Total difficulty</div>
            <div class="text-4xl font-bold text-accent-900 mt-1 leading-none" style="font-family: var(--font-serif);">@Difficulty</div>
        </div>
        <div class="text-xs text-accent-800/70 text-right space-y-0.5">
            @if (isFreeplay)
            {
                <div>Tutorial / freeplay</div>
            }
            else
            {
                @foreach (var (item, adv) in adversaries)
                {
                    var mode = adv!.Modes.FirstOrDefault(m => m.Level == item.Level);
                    <div>@adv.Name L@(item.Level) <span class="text-accent-700/60">+@(mode?.Difficulty ?? 0)</span></div>
                }
                @if (scenario is not null)
                {
                    <div>@scenario.Name <span class="text-accent-700/60">+@scenario.Difficulty</span></div>
                }
                @if (ExtraBoard)
                {
                    <div>Extra board <span class="text-accent-700/60">+@GameRestrictions.ExtraBoardDifficultyBonus</span></div>
                }
                @if (ThematicMaps)
                {
                    <div>Thematic maps <span class="text-accent-700/60">+@GameRestrictions.ThematicMapsDifficultyBonus</span></div>
                }
                @if (DifficultyModifier != 0)
                {
                    <div>Modifier <span class="text-accent-700/60">@(DifficultyModifier > 0 ? "+" : "")@DifficultyModifier</span></div>
                }
            }
        </div>
    </div>

    @* Island layout *@
    <div class="px-5 md:px-6 py-5 flex items-center gap-4">
        <div class="h-20 w-20 shrink-0 flex items-center justify-center">
            <IslandSetupDiagram Setup="setup" Class="max-h-full max-w-full"/>
        </div>
        <div class="min-w-0 flex-1">
            <div class="text-[10px] uppercase tracking-wide text-ink-500 font-medium">Island setup</div>
            <div class="mt-0.5 text-base font-semibold text-ink-900 truncate">
                @(setup?.Name ?? "Unknown layout")
            </div>
            <div class="mt-1 flex flex-wrap items-center gap-1.5">
                @if (setup is not null)
                {
                    <span class="text-[11px] text-ink-500">@setup.NumberOfPlayers @(setup.NumberOfPlayers == 1 ? "board" : "boards")</span>
                }
                @if (ThematicMaps)
                {
                    <span class="inline-flex items-center text-[10px] uppercase tracking-wider text-accent-700 bg-accent-50 px-1.5 py-0.5 rounded">Thematic</span>
                }
                @if (ExtraBoard)
                {
                    <span class="inline-flex items-center text-[10px] uppercase tracking-wider text-accent-700 bg-accent-50 px-1.5 py-0.5 rounded">Extra board</span>
                }
            </div>
        </div>
    </div>

    @* Adversaries *@
    @if (adversaries.Count > 0)
    {
        <div class="px-5 md:px-6 py-4 border-t border-ink-100">
            <div class="text-[10px] uppercase tracking-wide text-ink-500 font-medium mb-2">
                @(adversaries.Count > 1 ? "Adversaries" : "Adversary")
            </div>
            <div class="grid sm:grid-cols-2 gap-2.5">
                @foreach (var (item, adv) in adversaries)
                {
                    var mode = adv!.Modes.FirstOrDefault(m => m.Level == item.Level);
                    <div class="flex items-center gap-3 rounded-lg border border-ink-200 bg-white p-3">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent-50 text-accent-700 shrink-0">
                            <Icon Name="shield" Class="w-4 h-4"/>
                        </span>
                        <div class="min-w-0 flex-1">
                            <div class="text-sm font-semibold text-ink-900 truncate">@adv.Name</div>
                            <div class="text-[11px] text-ink-500">Level @item.Level · +@(mode?.Difficulty ?? 0) difficulty</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* Scenario *@
    @if (scenario is not null)
    {
        <div class="px-5 md:px-6 py-4 border-t border-ink-100">
            <div class="text-[10px] uppercase tracking-wide text-ink-500 font-medium mb-2">Scenario</div>
            <div class="flex items-center gap-3 rounded-lg border border-ink-200 bg-white p-3">
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent-100 text-accent-700 shrink-0">
                    <Icon Name="book" Class="w-4 h-4"/>
                </span>
                <div class="min-w-0 flex-1">
                    <div class="text-sm font-semibold text-ink-900 truncate">@scenario.Name</div>
                    <div class="text-[11px] text-ink-500">+@scenario.Difficulty difficulty</div>
                </div>
            </div>
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public string IslandSetupId { get; set; } = "";
    [Parameter] public bool ExtraBoard { get; set; }
    [Parameter] public bool ThematicMaps { get; set; }
    [Parameter] public int Difficulty { get; set; }
    [Parameter] public int DifficultyModifier { get; set; }
    [Parameter] public string? ScenarioId { get; set; }
    [Parameter] public IReadOnlyList<Application.Features.Games.Dtos.GameAdversaryResponse> Adversaries { get; set; } = [];
}
