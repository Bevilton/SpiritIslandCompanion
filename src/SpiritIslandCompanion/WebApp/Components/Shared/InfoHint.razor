@* Compact help marker — circular (i) icon that reveals a tooltip on hover or focus.
   Usage:
       <InfoHint>Some explanation text…</InfoHint>
       <InfoHint Position="right">Anchored to the right edge.</InfoHint>
*@

<span class="relative inline-block align-middle">
    <button type="button"
            class="peer inline-flex h-4 w-4 items-center justify-center rounded-full bg-ink-100 text-ink-500 hover:bg-ink-200 hover:text-ink-700 focus:outline-none focus:ring-2 focus:ring-accent-500/40 transition-colors"
            tabindex="0"
            aria-label="More info">
        <Icon Name="info" Class="w-3 h-3"/>
    </button>
    <div class="@PanelClass">
        @ChildContent
    </div>
</span>

@code {
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }

    /// <summary>"left" (default), "right", or "center" — anchors the popover horizontally.</summary>
    [Parameter] public string Position { get; set; } = "left";

    private string PanelClass =>
        "hidden peer-hover:block peer-focus:block "
        + Position switch
        {
            "right"  => "right-0 ",
            "center" => "left-1/2 -translate-x-1/2 ",
            _        => "left-0 "
        }
        + "absolute z-40 top-full mt-1.5 w-64 rounded-lg shadow-lg border border-ink-200 bg-white p-3 text-xs leading-relaxed text-ink-700 normal-case tracking-normal font-normal";
}
