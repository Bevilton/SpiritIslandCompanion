@if (_visible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center px-4">
        <div class="absolute inset-0 bg-ink-900/40 backdrop-blur-sm" @onclick="Cancel"></div>
        <div class="relative bg-white rounded-xl shadow-xl border border-ink-200 w-full max-w-md">
            <div class="px-6 pt-6 pb-2">
                <h3 class="text-lg font-semibold text-ink-900">@Title</h3>
                <p class="mt-2 text-sm text-ink-600">@Message</p>
            </div>
            <div class="px-6 py-4 flex justify-end gap-2">
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                <button type="button" class="btn btn-danger" @onclick="Confirm">@ConfirmText</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _visible;
    private TaskCompletionSource<bool>? _tcs;

    [Parameter] public string Title { get; set; } = "Confirm";
    [Parameter] public string Message { get; set; } = "Are you sure?";
    [Parameter] public string ConfirmText { get; set; } = "Delete";

    public Task<bool> ShowAsync(string? message = null)
    {
        if (message is not null) Message = message;
        _visible = true;
        _tcs = new TaskCompletionSource<bool>();
        StateHasChanged();
        return _tcs.Task;
    }

    private void Confirm()
    {
        _visible = false;
        _tcs?.SetResult(true);
    }

    private void Cancel()
    {
        _visible = false;
        _tcs?.SetResult(false);
    }
}
