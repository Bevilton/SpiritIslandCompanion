@* Visual spirit picker. Shown as a modal with search + filters; selecting a spirit
   raises OnSelected and closes. Use as:
       <SpiritPickerModal @ref="_picker" OnSelected="HandleSelected"/>
       _picker.Show(currentSpiritId);
*@
@inject WebApp.State.OwnedExpansionsState ExpansionsState

@if (_open)
{
    <div class="fixed inset-0 z-50 flex items-end md:items-center justify-center px-0 md:px-4 py-0 md:py-8" role="dialog" aria-modal="true">
        <div class="absolute inset-0 bg-ink-900/40 backdrop-blur-sm" @onclick="Close"></div>

        <div class="relative bg-white w-full md:max-w-4xl md:rounded-2xl shadow-2xl border border-ink-200 overflow-hidden max-h-[92vh] flex flex-col">
            @* Header *@
            <div class="px-6 pt-5 pb-4 border-b border-ink-200 flex items-start gap-4">
                <div class="min-w-0 flex-1">
                    <h2 class="text-xl font-semibold text-ink-900 leading-tight" style="font-family: var(--font-serif);">
                        Choose a spirit
                    </h2>
                    <p class="text-xs text-ink-500 mt-1">
                        @_visibleCount of @_totalSpiritsInScope spirits
                    </p>
                </div>
                <input type="search" class="input md:w-56" placeholder="Search by name…" @bind="_query" @bind:event="oninput"/>
                <button class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-ink-500 hover:bg-ink-100 hover:text-ink-900 transition-colors shrink-0" @onclick="Close" aria-label="Close">
                    <Icon Name="x" Class="w-5 h-5"/>
                </button>
            </div>

            @* Filters bar *@
            <div class="px-6 py-3 border-b border-ink-200 bg-ink-50/50 flex flex-wrap items-center gap-x-3 gap-y-2 text-xs">
                <span class="text-[10px] uppercase tracking-wider text-ink-500 font-medium">Filters</span>

                <div class="flex flex-wrap gap-1">
                    @foreach (var c in _allComplexities)
                    {
                        <FilterPill Active="@_selectedComplexities.Contains(c)" OnToggle="() => Toggle(_selectedComplexities, c)">
                            @ComplexityLabel(c)
                        </FilterPill>
                    }
                </div>

                <span class="text-ink-300">|</span>

                <div class="flex flex-wrap gap-1">
                    @foreach (var el in _allElements)
                    {
                        <FilterPill Active="@_selectedElements.Contains(el)" OnToggle="() => Toggle(_selectedElements, el)">
                            <ElementBadges Elements="@(new[] { el })" Size="sm"/>
                        </FilterPill>
                    }
                </div>

                @if (HasActiveFilters)
                {
                    <button type="button" class="ml-auto text-accent-700 hover:text-accent-800 hover:underline text-xs" @onclick="ClearFilters">
                        Clear filters
                    </button>
                }
            </div>

            @* Body *@
            <div class="overflow-y-auto px-6 py-5">
                @foreach (var grp in _byExpansion)
                {
                    var visible = grp.Spirits.Where(MatchesFilters).ToList();
                    if (visible.Count == 0) { continue; }

                    <div class="mb-6 last:mb-0">
                        <div class="text-[11px] font-medium uppercase tracking-wider text-ink-500 mb-2">@grp.Expansion.Name</div>
                        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2.5">
                            @foreach (var s in visible)
                            {
                                var detail = SpiritDetails.For(s.Id);
                                var color = detail?.ColorHex ?? "#78716c";
                                var isSelected = _currentSpiritId == s.Id.Value;

                                <button type="button"
                                        @onclick="() => Pick(s)"
                                        class="@(isSelected ? "ring-2 ring-accent-500 border-accent-300" : "border-ink-200 hover:border-ink-300")
                                               relative text-left bg-white border rounded-xl p-4 transition-all hover:shadow-sm hover:-translate-y-px focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-500/40"
                                        style="border-top: 3px solid @color;">
                                    @if (isSelected)
                                    {
                                        <span class="absolute top-2 right-2 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent-600 text-white">
                                            <Icon Name="check" Class="w-3 h-3"/>
                                        </span>
                                    }
                                    <div class="flex items-start justify-between gap-2 pr-6">
                                        <div class="min-w-0">
                                            <h3 class="text-sm font-semibold leading-snug text-ink-900">@s.Name</h3>
                                            @if (detail is not null)
                                            {
                                                <div class="mt-0.5 text-[11px] text-ink-500">@detail.PlayStyle</div>
                                            }
                                        </div>
                                        @if (detail is not null)
                                        {
                                            <ElementBadges Elements="detail.Elements" Size="sm"/>
                                        }
                                    </div>
                                    @if (detail is not null)
                                    {
                                        <div class="mt-2 flex items-center gap-1.5 flex-wrap">
                                            <span class="badge text-[10px]" style="background-color: @(color)1f; color: @color;">
                                                @ComplexityLabel(detail.Complexity)
                                            </span>
                                            @if (detail.Tokens.Count > 0)
                                            {
                                                <TokenBadges Tokens="detail.Tokens" Size="sm"/>
                                            }
                                        </div>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                }

                @if (_visibleCount == 0)
                {
                    <div class="text-center py-10 text-ink-500 text-sm">
                        No spirits match the current filters.
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback<Spirit> OnSelected { get; set; }

    private bool _open;
    private string? _currentSpiritId;
    private string _query = "";

    private readonly HashSet<Complexity> _selectedComplexities = new();
    private readonly HashSet<Element> _selectedElements = new();

    private IReadOnlyList<ExpansionId>? OwnedExpansions => ExpansionsState.Current;

    private static readonly Complexity[] _allComplexities =
        [Complexity.Low, Complexity.Moderate, Complexity.High, Complexity.VeryHigh];

    private static readonly Element[] _allElements =
        [Element.Sun, Element.Moon, Element.Fire, Element.Air, Element.Water, Element.Earth, Element.Plant, Element.Animal];

    public async Task ShowAsync(string? currentSpiritId = null)
    {
        await ExpansionsState.EnsureLoadedAsync();
        _currentSpiritId = currentSpiritId;
        _query = "";
        _selectedComplexities.Clear();
        _selectedElements.Clear();
        _open = true;
        StateHasChanged();
    }

    public void Show(string? currentSpiritId = null) => _ = ShowAsync(currentSpiritId);

    private void Close()
    {
        _open = false;
        StateHasChanged();
    }

    private async Task Pick(Spirit s)
    {
        _open = false;
        StateHasChanged();
        await OnSelected.InvokeAsync(s);
    }

    private static void Toggle<T>(HashSet<T> set, T value)
    {
        if (!set.Add(value)) { set.Remove(value); }
    }

    private void ClearFilters()
    {
        _selectedComplexities.Clear();
        _selectedElements.Clear();
    }

    private bool HasActiveFilters =>
        _selectedComplexities.Count > 0 || _selectedElements.Count > 0;

    private record ExpansionGroup(Expansion Expansion, IReadOnlyList<Spirit> Spirits);

    private IReadOnlyList<ExpansionGroup> _byExpansion =>
        GameData.Expansions
            .Where(e => OwnedExpansions is null || OwnedExpansions.Contains(e.Id))
            .Select(e => new ExpansionGroup(
                e,
                GameData.Spirits.Where(s => s.ExpansionId == e.Id).ToList()))
            .Where(g => g.Spirits.Count > 0)
            .ToList();

    private int _totalSpiritsInScope => _byExpansion.Sum(g => g.Spirits.Count);

    private int _visibleCount => _byExpansion.Sum(g => g.Spirits.Count(MatchesFilters));

    private bool MatchesFilters(Spirit s)
    {
        if (!string.IsNullOrWhiteSpace(_query) && !s.Name.Contains(_query, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var detail = SpiritDetails.For(s.Id);
        if (detail is null)
        {
            return _selectedComplexities.Count == 0 && _selectedElements.Count == 0;
        }

        if (_selectedComplexities.Count > 0 && !_selectedComplexities.Contains(detail.Complexity))
        {
            return false;
        }

        if (_selectedElements.Count > 0 && !detail.Elements.Any(_selectedElements.Contains))
        {
            return false;
        }

        return true;
    }

    private static string ComplexityLabel(Complexity c) => c switch
    {
        Complexity.Low      => "Low",
        Complexity.Moderate => "Moderate",
        Complexity.High     => "High",
        Complexity.VeryHigh => "Very high",
        _ => c.ToString()
    };
}
