@* Large stat card for the overview top-row. Bigger and richer than StatCard:
   supports a side-bar accent colour, a caption line, and an optional click
   action (navigate to a related entity). *@

@{
    var clickable = !string.IsNullOrEmpty(Href);
    var tag = clickable ? "a" : "div";
    var attrs = clickable
        ? new Dictionary<string, object> { ["href"] = Href! }
        : null;
}

<div class="@WrapperClass" style="@(string.IsNullOrEmpty(AccentColor) ? null : $"border-left: 4px solid {AccentColor};")">
    <div class="flex items-start justify-between gap-3 h-full">
        <div class="min-w-0 flex flex-col gap-1.5">
            <div class="text-[10px] uppercase tracking-wide text-ink-500 font-medium">@Label</div>
            <div class="text-2xl md:text-3xl font-bold text-ink-900 leading-none tabular-nums" style="font-family: var(--font-serif);">@Value</div>
            @if (!string.IsNullOrEmpty(Caption))
            {
                <div class="text-xs text-ink-500 leading-snug">@Caption</div>
            }
        </div>
        @if (!string.IsNullOrEmpty(Icon))
        {
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent-50 text-accent-700 shrink-0">
                <Icon Name="@Icon" Class="w-4 h-4"/>
            </span>
        }
    </div>
    @if (Href is not null)
    {
        <a href="@Href" class="absolute inset-0" aria-label="@Label"></a>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string? Caption { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? AccentColor { get; set; }

    private string WrapperClass => Href is null
        ? "stat-tile relative"
        : "stat-tile relative hover:border-accent-300 hover:bg-accent-50/30 transition-colors";
}
