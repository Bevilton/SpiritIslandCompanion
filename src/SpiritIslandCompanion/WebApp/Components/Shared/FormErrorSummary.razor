@using WebApp.Validation

@if (Errors is { Any: true })
{
    <div class="alert alert-danger mb-4" role="alert">
        <Icon Name="x" Class="w-5 h-5 shrink-0 mt-0.5"/>
        <div class="flex-1">
            <div class="font-medium">@(Errors.All.Count == 1 ? "Please fix the following:" : $"Please fix the following {Errors.All.Count} issues:")</div>
            <ul class="mt-1 list-disc list-inside text-sm space-y-0.5">
                @foreach (var msg in Errors.All)
                {
                    <li>@msg</li>
                }
            </ul>
        </div>
    </div>
}

@code {
    [Parameter] public FormErrors? Errors { get; set; }
}
