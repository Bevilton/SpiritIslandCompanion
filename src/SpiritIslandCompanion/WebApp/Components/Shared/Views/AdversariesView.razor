@* Reference content for adversaries. Used from /adversaries (public) and /app/adversaries. *@
@inject WebApp.State.OwnedExpansionsState ExpansionsState
@implements IDisposable

<div class="page-head">
    <div>
        <span class="eyebrow">Reference</span>
        <h1 class="page-title mt-2">Adversaries</h1>
        <p class="page-sub">@_adversariesInScope.Count adversaries with their difficulty progression.</p>
    </div>
    <input type="search" class="input md:w-64" placeholder="Filter by name…" @bind="_query" @bind:event="oninput"/>
</div>

<div class="surface p-4 mt-4">
    <div class="flex items-start gap-3 flex-wrap">
        <span class="text-[11px] uppercase tracking-wide text-ink-500 w-20 shrink-0 mt-1">Expansion</span>
        <div class="flex flex-wrap gap-1.5 flex-1">
            @foreach (var e in GameData.Expansions.Where(x => OwnedExpansions is null || OwnedExpansions.Contains(x.Id)))
            {
                <FilterPill Active="@_selectedExpansions.Contains(e.Id.Value)"
                            OnToggle="() => ToggleExpansion(e.Id.Value)">
                    @e.Name
                </FilterPill>
            }
        </div>
        @if (_selectedExpansions.Count > 0)
        {
            <button type="button" class="text-xs text-accent-700 hover:text-accent-800 hover:underline mt-1" @onclick="() => _selectedExpansions.Clear()">
                Clear
            </button>
        }
    </div>
</div>

<div class="grid lg:grid-cols-2 gap-4 mt-6">
    @foreach (var a in _filtered)
    {
        var modes = a.Modes.OrderBy(m => m.Level).ToList();
        var detail = AdversaryDetails.For(a.Id);
        <button type="button"
                @onclick="() => OpenDetail(a)"
                class="text-left surface p-5 md:p-6 transition-all hover:shadow-sm hover:-translate-y-px focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-500/40">
            <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                    <h3 class="text-lg font-semibold leading-tight">@a.Name</h3>
                    <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-ink-500">
                        <span>@ExpansionName(a.ExpansionId)</span>
                        @if (detail is not null)
                        {
                            <span>·</span>
                            <span>@detail.Theme</span>
                        }
                    </div>
                </div>
                <Icon Name="shield" Class="w-5 h-5 text-accent-600 shrink-0"/>
            </div>

            <div class="mt-5">
                <div class="text-xs uppercase tracking-wide text-ink-500 mb-2">Difficulty by level</div>
                <div class="grid grid-cols-7 gap-1.5">
                    @foreach (var m in modes)
                    {
                        <div class="rounded-md border border-ink-200 bg-ink-50/60 px-1 py-2 text-center">
                            <div class="text-[10px] uppercase text-ink-500">L@(m.Level)</div>
                            <div class="text-sm font-semibold text-ink-900">@m.Difficulty</div>
                        </div>
                    }
                </div>
            </div>
        </button>
    }
</div>

@if (!_filtered.Any())
{
    <div class="surface text-center py-10 mt-6 text-ink-500">No adversaries match the current filters.</div>
}

<AdversaryDetailModal @ref="_modal"/>

@code {
    private string _query = "";
    private readonly HashSet<string> _selectedExpansions = new();
    private AdversaryDetailModal _modal = default!;

    private IReadOnlyList<ExpansionId>? OwnedExpansions => ExpansionsState.Current;

    protected override async Task OnInitializedAsync()
    {
        ExpansionsState.Changed += OnExpansionsChanged;
        await ExpansionsState.EnsureLoadedAsync();
    }

    private void OnExpansionsChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => ExpansionsState.Changed -= OnExpansionsChanged;

    private void OpenDetail(Adversary a) => _modal.Show(a);

    private static readonly Dictionary<string, string> _expansionNames =
        GameData.Expansions.ToDictionary(e => e.Id.Value, e => e.Name);

    private static readonly Dictionary<string, int> _expansionOrder =
        GameData.Expansions
            .Select((e, i) => (e.Id.Value, i))
            .ToDictionary(x => x.Value, x => x.i);

    private IReadOnlyList<Adversary> _adversariesInScope =>
        GameData.Adversaries
            .Where(a => OwnedExpansions is null || OwnedExpansions.Contains(a.ExpansionId))
            .ToList();

    private IEnumerable<Adversary> _filtered =>
        _adversariesInScope
            .Where(a =>
                (string.IsNullOrWhiteSpace(_query) || a.Name.Contains(_query, StringComparison.OrdinalIgnoreCase))
                && (_selectedExpansions.Count == 0 || _selectedExpansions.Contains(a.ExpansionId.Value)))
            .OrderBy(a => _expansionOrder.GetValueOrDefault(a.ExpansionId.Value, int.MaxValue))
            .ThenBy(a => a.Name);

    private void ToggleExpansion(string id)
    {
        if (!_selectedExpansions.Add(id)) { _selectedExpansions.Remove(id); }
    }

    private static string ExpansionName(ExpansionId id)
        => _expansionNames.GetValueOrDefault(id.Value, id.Value);
}
