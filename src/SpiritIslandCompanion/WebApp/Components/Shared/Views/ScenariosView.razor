@* Reference content for scenarios. Used from /scenarios (public) and /app/scenarios. *@

<div class="page-head">
    <div>
        <span class="eyebrow">Reference</span>
        <h1 class="page-title mt-2">Scenarios</h1>
        <p class="page-sub">@GameData.Scenarios.Count special scenarios that change how the game plays.</p>
    </div>
    <input type="search" class="input md:w-64" placeholder="Filter by name…" @bind="_query" @bind:event="oninput"/>
</div>

<div class="surface p-4 mt-4">
    <div class="flex items-start gap-3 flex-wrap">
        <span class="text-[11px] uppercase tracking-wide text-ink-500 w-20 shrink-0 mt-1">Expansion</span>
        <div class="flex flex-wrap gap-1.5 flex-1">
            @foreach (var e in GameData.Expansions)
            {
                <FilterPill Active="@_selectedExpansions.Contains(e.Id.Value)"
                            OnToggle="() => ToggleExpansion(e.Id.Value)">
                    @e.Name
                </FilterPill>
            }
        </div>
        @if (_selectedExpansions.Count > 0)
        {
            <button type="button" class="text-xs text-accent-700 hover:text-accent-800 hover:underline mt-1" @onclick="() => _selectedExpansions.Clear()">
                Clear
            </button>
        }
    </div>
</div>

<div class="surface mt-6">
    <div class="table-wrap">
        <table class="table">
            <thead>
            <tr>
                <th>Scenario</th>
                <th>Expansion</th>
                <th class="text-right">Difficulty</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var s in _filtered)
            {
                <tr>
                    <td class="font-medium text-ink-900">@s.Name</td>
                    <td class="text-ink-500">@ExpansionName(s.ExpansionId)</td>
                    <td class="text-right">
                        <span class="badge @(s.Difficulty >= 3 ? "badge-warn" : s.Difficulty >= 1 ? "badge-info" : "badge-neutral")">
                            +@s.Difficulty
                        </span>
                    </td>
                </tr>
            }
            @if (!_filtered.Any())
            {
                <tr><td colspan="3" class="text-center text-ink-500 py-6">No scenarios match.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>

@code {
    private string _query = "";
    private readonly HashSet<string> _selectedExpansions = new();

    private static readonly Dictionary<string, string> _expansionNames =
        GameData.Expansions.ToDictionary(e => e.Id.Value, e => e.Name);

    private static readonly Dictionary<string, int> _expansionOrder =
        GameData.Expansions
            .Select((e, i) => (e.Id.Value, i))
            .ToDictionary(x => x.Value, x => x.i);

    private IEnumerable<Scenario> _filtered =>
        GameData.Scenarios
            .Where(s =>
                (string.IsNullOrWhiteSpace(_query) || s.Name.Contains(_query, StringComparison.OrdinalIgnoreCase))
                && (_selectedExpansions.Count == 0 || _selectedExpansions.Contains(s.ExpansionId.Value)))
            .OrderBy(s => _expansionOrder.GetValueOrDefault(s.ExpansionId.Value, int.MaxValue))
            .ThenBy(s => s.Difficulty)
            .ThenBy(s => s.Name);

    private void ToggleExpansion(string id)
    {
        if (!_selectedExpansions.Add(id)) { _selectedExpansions.Remove(id); }
    }

    private static string ExpansionName(ExpansionId id)
        => _expansionNames.GetValueOrDefault(id.Value, id.Value);
}
