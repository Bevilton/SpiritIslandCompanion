@if (_spirit is not null)
{
    var detail = _detail;
    var color = detail?.ColorHex ?? "#78716c";

    <div class="fixed inset-0 z-50 flex items-end md:items-center justify-center px-0 md:px-4 py-0 md:py-8" role="dialog" aria-modal="true">
        <div class="absolute inset-0 bg-ink-900/40 backdrop-blur-sm" @onclick="Close"></div>

        <div class="relative bg-white w-full md:max-w-2xl md:rounded-2xl shadow-2xl border border-ink-200 overflow-hidden max-h-[92vh] flex flex-col">
            @* Header band coloured by the spirit *@
            <div class="px-6 pt-6 pb-5 relative" style="background: linear-gradient(135deg, @(color)18 0%, @(color)08 100%); border-bottom: 1px solid @(color)33;">
                <button class="absolute top-4 right-4 inline-flex h-8 w-8 items-center justify-center rounded-lg text-ink-500 hover:bg-white/60 hover:text-ink-900 transition-colors" @onclick="Close" aria-label="Close">
                    <Icon Name="x" Class="w-5 h-5"/>
                </button>

                <div class="flex items-start gap-4 pr-10">
                    <span class="inline-block w-1.5 self-stretch rounded-full shrink-0" style="background-color: @color;"></span>
                    <div class="min-w-0 flex-1">
                        <h2 class="text-2xl font-semibold text-ink-900 leading-tight" style="font-family: var(--font-serif);">@_spirit.Name</h2>
                        <div class="mt-1.5 flex flex-wrap items-center gap-2 text-xs">
                            <span class="badge badge-neutral">@ExpansionName(_spirit.ExpansionId)</span>
                            @if (detail is not null)
                            {
                                <span class="badge" style="background-color: @(color)20; color: @color;">
                                    @ComplexityLabel(detail.Complexity)
                                </span>
                                <span class="text-ink-600">· @detail.PlayStyle</span>
                            }
                        </div>
                        @if (detail is not null && (detail.Elements.Count > 0 || detail.Tokens.Count > 0))
                        {
                            <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2">
                                @if (detail.Elements.Count > 0)
                                {
                                    <div class="flex items-center gap-2">
                                        <span class="text-[10px] uppercase tracking-wide text-ink-500">Elements</span>
                                        <ElementBadges Elements="detail.Elements" Size="md"/>
                                    </div>
                                }
                                @if (detail.Tokens.Count > 0)
                                {
                                    <div class="flex items-center gap-2">
                                        <span class="text-[10px] uppercase tracking-wide text-ink-500">Tokens</span>
                                        <TokenBadges Tokens="detail.Tokens" Size="md"/>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Body *@
            <div class="overflow-y-auto px-6 py-5 space-y-6">
                @if (detail is not null)
                {
                    <p class="text-ink-700 leading-relaxed">@detail.Summary</p>
                }
                else
                {
                    <p class="text-ink-500 italic">No additional information available.</p>
                }

                @if (_aspects.Count > 0)
                {
                    <div>
                        <h3 class="text-sm font-medium uppercase tracking-wide text-ink-500 mb-3">Aspects</h3>
                        <ul class="space-y-3">
                            @foreach (var aspect in _aspects)
                            {
                                var aspectDetail = AspectDetails.For(aspect.Id);
                                <li class="rounded-lg border border-ink-200 p-4">
                                    <div class="flex items-center gap-2">
                                        <span class="h-2 w-2 rounded-full shrink-0" style="background-color: @color;"></span>
                                        <span class="font-medium text-ink-900">@aspect.Name</span>
                                        <span class="ml-auto text-[11px] uppercase tracking-wide text-ink-400">@ExpansionName(aspect.ExpansionId)</span>
                                    </div>
                                    @if (aspectDetail is not null)
                                    {
                                        <p class="mt-2 text-sm text-ink-600 leading-relaxed">@aspectDetail.Summary</p>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }

                <div class="pt-2">
                    <a href="@WikiLink(_spirit.Name)" target="_blank" rel="noopener"
                       class="inline-flex items-center gap-1 text-sm text-accent-700 hover:text-accent-800">
                        Read on the Spirit Island wiki
                        <Icon Name="arrow-right" Class="w-3.5 h-3.5"/>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Spirit? _spirit;
    private SpiritDetail? _detail;
    private IReadOnlyList<Aspect> _aspects = [];

    private static readonly Dictionary<string, string> _expansionNames =
        GameData.Expansions.ToDictionary(e => e.Id.Value, e => e.Name);

    public void Show(Spirit spirit)
    {
        _spirit = spirit;
        _detail = SpiritDetails.For(spirit.Id);
        _aspects = GameData.GetAspectsForSpirit(spirit.Id);
        StateHasChanged();
    }

    public void Close()
    {
        _spirit = null;
        _detail = null;
        _aspects = [];
        StateHasChanged();
    }

    private static string ExpansionName(ExpansionId id)
        => _expansionNames.GetValueOrDefault(id.Value, id.Value);

    private static string ComplexityLabel(Complexity c) => c switch
    {
        Complexity.Low      => "Low complexity",
        Complexity.Moderate => "Moderate",
        Complexity.High     => "High",
        Complexity.VeryHigh => "Very high",
        _ => c.ToString()
    };

    private static string WikiLink(string spiritName)
    {
        var slug = spiritName.Replace("'", "%27").Replace(" ", "_");
        return $"https://spiritislandwiki.com/index.php?title={slug}";
    }
}
