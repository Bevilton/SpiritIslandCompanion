<div class="flex items-center gap-3 min-w-[140px]">
    <div class="flex-1 h-1.5 bg-ink-100 rounded-full overflow-hidden">
        <div class="h-full bg-accent-500 rounded-full" style="width:@($"{Math.Clamp(Pct, 0, 100):F0}")%"></div>
    </div>
    <span class="text-xs text-ink-700 tabular-nums w-9 text-right">@($"{Pct:F0}%")</span>
</div>

@code {
    [Parameter, EditorRequired] public double Pct { get; set; }
}
